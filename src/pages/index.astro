---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import CallToAction from "../components/CallToAction.astro";
import Testimonials from "../components/Testimonials.astro";
import Footer from "../components/Footer.astro";
import Products from "../components/Products.astro";
import MobileCTA from "../components/MobileCTA.astro";


---

<Layout
  title="El sabor de la tradición | Chocolates Taboada"
  description="Descubre Chocolates Taboada, la primera industria chocolatera de Bolivia desde 1948. Tradición, elegancia y un sabor inolvidable."
>
  <Navbar />

  <header
    id="inicio"
    class="relative min-h-screen overflow-hidden bg-[#14080d]"
  >
    <div
      id="hero-bg-cover"
      class="absolute inset-0 bg-no-repeat
           bg-cover bg-[position:80%_center] scale-100
           lg:bg-center lg:scale-105 transition-all duration-700"
      data-bg-cochabamba="/img/portadataboada.png"
      data-bg-lapaz="/img/portadalapaz.png"
      style="background-image:url('/img/portadataboada.png')"
    >
    </div>

    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,rgba(10,5,7,0.96)_0%,rgba(20,10,15,0.92)_20%,rgba(38,18,25,0.82)_42%,rgba(62,28,40,0.58)_68%,rgba(120,70,85,0.18)_88%,rgba(255,255,255,0)_100%)]"
    >
    </div>

    <!-- BRILLO PREMIUM -->

    <div
      class="absolute top-[-180px] left-[-120px] w-[500px] h-[500px] rounded-full bg-[#f6d98d]/10 blur-[120px]"
    >
    </div>

    <!-- PARTICULAS -->

    <div class="absolute inset-0 overflow-hidden z-[2]">
      <!-- LUCES -->

      <span
        class="absolute top-[52%] left-[20%] w-2 h-2 rounded-full bg-[#F6D983] shadow-[0_0_20px_rgba(255,220,120,0.9)] animate-float"
      ></span>

      <span
        class="absolute top-[48%] left-[34%] w-1 h-1 rounded-full bg-[#F6D983] shadow-[0_0_20px_rgba(255,220,120,0.9)] animate-float [animation-delay:1s]"
      ></span>

      <span
        class="absolute top-[58%] left-[48%] w-2 h-2 rounded-full bg-[#F6D983] shadow-[0_0_20px_rgba(255,220,120,0.9)] animate-float [animation-delay:2s]"
      ></span>

      <span
        class="absolute top-[66%] left-[64%] w-1.5 h-1.5 rounded-full bg-[#F6D983] shadow-[0_0_20px_rgba(255,220,120,0.9)] animate-float [animation-delay:3s]"
      ></span>

      <!-- PETALOS (SVG inline) -->

      <!-- CHOCOLATE Y CACAO FALL (SVGs) -->
      <svg class="chocolate-fall absolute left-[5%] w-3 opacity-60" style="animation-duration:9s; animation-delay:2.5s;" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="5" cy="5" r="4" fill="#3D1C06" /></svg>
      <svg class="chocolate-fall absolute left-[12%] w-7 opacity-75" style="animation-duration:14s; animation-delay:0s;" viewBox="0 0 40 60" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20,10 C32,20 32,40 20,50 C8,40 8,20 20,10 Z" fill="#3D1C06" /><path d="M20,15 C24,22 24,38 20,45" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round" opacity="0.6" /></svg>
      <svg class="chocolate-fall absolute left-[22%] w-5 opacity-60" style="animation-duration:9s; animation-delay:1s;" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15,5 L17,12 L24,15 L17,18 L15,25 L13,18 L6,15 L13,12 Z" fill="#2A1612" /></svg>
      <svg class="chocolate-fall absolute left-[33%] w-5 opacity-65" style="animation-duration:13s; animation-delay:6s;" viewBox="0 0 40 60" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20,15 C28,23 28,37 20,45 C12,37 12,23 20,15 Z" fill="#42200D" /></svg>
      <svg class="chocolate-fall absolute left-[45%] w-8 opacity-80" style="animation-duration:11s; animation-delay:3s;" viewBox="0 0 40 60" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20,12 C30,22 30,38 20,48 C10,38 10,22 20,12 Z" fill="#5C3821" /><path d="M20,17 C23,24 23,36 20,43" stroke="#F6D98D" stroke-width="1.2" stroke-linecap="round" opacity="0.5" /></svg>
      <svg class="chocolate-fall absolute left-[53%] w-4 opacity-60" style="animation-duration:12s; animation-delay:5s;" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><polygon points="10,3 17,7 15,15 7,17 3,10" fill="#2E160A" /></svg>
      <svg class="chocolate-fall absolute left-[62%] w-4 opacity-75" style="animation-duration:8s; animation-delay:4s;" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15,7 L17,12 L22,15 L17,18 L15,23 L13,18 L8,15 L13,12 Z" fill="#D4AF37" /></svg>
      <svg class="chocolate-fall absolute left-[70%] w-3 opacity-80" style="animation-duration:7s; animation-delay:0.5s;" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="5" cy="5" r="4" fill="#D4AF37" /></svg>
      <svg class="chocolate-fall absolute left-[78%] w-6 opacity-70" style="animation-duration:16s; animation-delay:1.5s;" viewBox="0 0 40 60" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20,10 C32,20 32,40 20,50 C8,40 8,20 20,10 Z" fill="url(#goldGrad)" /><defs><linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#D4AF37" /><stop offset="50%" stop-color="#F6D98D" /><stop offset="100%" stop-color="#AA7C11" /></linearGradient></defs></svg>
      <svg class="chocolate-fall absolute left-[88%] w-5 opacity-70" style="animation-duration:10s; animation-delay:2s;" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15,5 L17,12 L24,15 L17,18 L15,25 L13,18 L6,15 L13,12 Z" fill="#7A4B29" /></svg>
      <svg class="chocolate-fall absolute left-[93%] w-2.5 opacity-75" style="animation-duration:8s; animation-delay:7s;" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="5" cy="5" r="4" fill="#F6D98D" /></svg>
    </div>

    <!-- CONTENIDO -->

    <div
      class="relative z-[5] w-full max-w-[1440px] mx-auto min-h-screen px-6 lg:pl-16 lg:pr-10 pt-[120px] pb-20 grid lg:grid-cols-2 items-center gap-8"
    >
      <!-- TEXTO -->

      <div class="max-w-[500px]">
        <!-- MINI TEXTO -->

        <div class="flex items-center gap-4 mb-6">
          <div
            class="w-10 h-[1px] bg-gradient-to-r from-[#f6d98d] to-transparent"
          >
          </div>

          <span
            class="uppercase tracking-[0.38em] text-[#f6d98d] text-[0.72rem] font-semibold"
          >
            TRADICIÓN DESDE 1948
          </span>
        </div>

        <!-- TITULO -->

        <h1
          class="font-playfair text-[clamp(3.2rem,6.5vw,5.5rem)] leading-[0.92] tracking-[-0.06em] text-[#fff7f8] drop-shadow-[0_12px_35px_rgba(0,0,0,0.45)]"
        >
          Tradición<br />

          <span class="text-[#f6d98d] italic font-[600]"> que deleita </span>
        </h1>

        <!-- TEXTO -->

        <p
          class="mt-6 text-[clamp(0.95rem,1.5vw,1.1rem)] leading-[1.8] text-[#f3dfe5]/75 max-w-[460px] font-light"
        >
          Disfruta del auténtico chocolate boliviano con más de siete décadas de historia.
          Elaborado con la más fina selección de cacao de nuestra tierra, manteniendo 
          recetas tradicionales de generación en generación.
        </p>

        <!-- BOTONES -->

        <div class="mt-10 flex flex-wrap items-center gap-3.5">
          <a
            href="#cajas-especiales"
            class="group inline-flex items-center gap-2.5 px-7 py-4 rounded-full bg-[linear-gradient(145deg,#f6d98d,#dcb041)] text-[#2e1119] font-bold text-xs md:text-sm shadow-[0_10px_25px_rgba(220,176,65,0.2)] hover:scale-[1.03] transition-all duration-500 relative overflow-hidden"
          >
            <span class="relative z-10 tracking-wide">✦ Ver Catalogo</span>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/60 to-transparent -translate-x-[130%] group-hover:animate-shimmer"></div>
          </a>

          <a
            href="/beneficios"
            class="group inline-flex items-center gap-2.5 px-7 py-4 rounded-full border border-warm-white/35 bg-warm-white/12 text-warm-white font-bold text-xs md:text-sm hover:scale-[1.03] hover:bg-warm-white/20 transition-all duration-500 relative overflow-hidden"
          >
            <span class="relative z-10 tracking-wide">Beneficios</span>
          </a>
        </div>
      </div>
    </div>
  </header>

  <section class="relative py-20 md:py-24 bg-[#FAF5F0] overflow-hidden border-y border-[#f0e6d8]">
    <!-- Sutil brillo decorativo de fondo -->
    <div class="absolute -right-20 top-1/2 -translate-y-1/2 w-48 h-48 bg-gradient-radial from-amber-200/10 to-transparent blur-3xl pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
      
      <!-- CABECERA SUAVE: Centrada y con fondo aclarado -->
<div class="w-full max-w-4xl mx-auto mb-12 p-8 rounded-2xl text-center">
  
  <!-- Categoría Centrada -->
  <div class="flex items-center justify-center gap-2 mb-4">
    <span class="w-6 h-[2px] bg-[#8f6c49]"></span>
    <span class="text-xs uppercase tracking-widest text-[#8f6c49] font-bold font-sans">Nuestra Propuesta</span>
    <span class="w-6 h-[2px] bg-[#8f6c49]"></span>
  </div>
  
  <!-- Título Principal Centrado -->
  <h2 class="font-serif text-3xl md:text-5xl text-[#2A1612] font-extrabold leading-tight tracking-tight mb-4">
    Calidad y elegancia en cada detalle.
  </h2>
  
  <!-- Mini Texto Agregado (Ajustado para Celular) -->
  <p class="text-sm md:text-base text-[#5D4037]/80 max-w-lg mx-auto leading-relaxed">
    Descubre combinaciones únicas de sabor, texturas delicadas y la tradición que nos caracteriza en cada pieza.
  </p>

</div>

      <!-- GRILLA DE BENEFICIOS / CARACTERÍSTICAS -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
        
        <!-- Tarjeta 1: Calidad Inigualable -->
        <div class="relative overflow-hidden rounded-[2rem] aspect-[3/4.2] group cursor-pointer shadow-lg hover:shadow-xl transition-all duration-500 flex flex-col justify-end p-6 bg-black/10">
          <!-- Imagen de fondo texturada -->
          <img 
            src="/img/razon2.png" 
            alt="Calidad Inigualable" 
            class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:scale-105 transition-transform duration-700 pointer-events-none" 
          />
          <!-- Overlay degradado oscuro gradual -->
          <div class="absolute inset-0 bg-gradient-to-t from-[#1A0A0C]/90 via-[#1A0A0C]/35 to-transparent z-0 transition-opacity duration-500"></div>
          <!-- Overlay café en hover -->
          <div class="absolute inset-0 bg-[#2A1612] opacity-0 group-hover:opacity-85 z-0 transition-opacity duration-500"></div>
          
          <!-- Contenido en la base -->
          <div class="relative z-10 flex flex-col items-start text-left text-white">
            <!-- Icono blanco -->
            <div class="w-12 h-12 rounded-full bg-white/10 backdrop-blur-md flex items-center justify-center mb-4 text-[#f6d98d] group-hover:bg-[#8f6c49]/80 group-hover:text-white transition-all duration-500">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="7" />
                <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88" />
              </svg>
            </div>
            
            <h3 class="font-serif font-bold text-lg md:text-xl text-white mb-2 leading-tight">Calidad Inigualable</h3>
            
            <!-- Descripción que se despliega elegantemente en hover -->
            <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-all duration-500 ease-in-out">
              <p class="overflow-hidden text-[11px] text-white/80 leading-relaxed font-sans transition-all duration-500">
                Cada pieza es el resultado de una selección minuciosa de los mejores granos de cacao. Garantizamos una textura excepcionalmente sedosa y un perfil de sabor profundo, diseñado para cautivar a los paladares más exigentes.
              </p>
            </div>
          </div>
        </div>

        <!-- Tarjeta 2: Maestría y Tradición -->
        <div class="relative overflow-hidden rounded-[2rem] aspect-[3/4.2] group cursor-pointer shadow-lg hover:shadow-xl transition-all duration-500 flex flex-col justify-end p-6 bg-black/10">
          <!-- Imagen de fondo texturada -->
          <img 
            src="/img/especial1.png" 
            alt="Maestría y Tradición" 
            class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:scale-105 transition-transform duration-700 pointer-events-none" 
          />
          <!-- Overlay degradado oscuro gradual -->
          <div class="absolute inset-0 bg-gradient-to-t from-[#1A0A0C]/90 via-[#1A0A0C]/35 to-transparent z-0 transition-opacity duration-500"></div>
          <!-- Overlay café en hover -->
          <div class="absolute inset-0 bg-[#2A1612] opacity-0 group-hover:opacity-85 z-0 transition-opacity duration-500"></div>
          
          <!-- Contenido en la base -->
          <div class="relative z-10 flex flex-col items-start text-left text-white">
            <!-- Icono blanco -->
            <div class="w-12 h-12 rounded-full bg-white/10 backdrop-blur-md flex items-center justify-center mb-4 text-[#f6d98d] group-hover:bg-[#8f6c49]/80 group-hover:text-white transition-all duration-500">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="16" y1="13" x2="8" y2="13" />
                <line x1="16" y1="17" x2="8" y2="17" />
              </svg>
            </div>
            
            <h3 class="font-serif font-bold text-lg md:text-xl text-white mb-2 leading-tight">Maestría y Tradición</h3>
            
            <!-- Descripción que se despliega elegantemente en hover -->
            <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-all duration-500 ease-in-out">
              <p class="overflow-hidden text-[11px] text-white/80 leading-relaxed font-sans transition-all duration-500">
                Respaldados por una profunda herencia chocolatera, fusionamos el arte de las recetas clásicas con altos estándares de elaboración. Es la verdadera esencia de la alta repostería llevada a su máxima expresión.
              </p>
            </div>
          </div>
        </div>

        <!-- Tarjeta 3: Ingredientes de Origen Noble -->
        <div class="relative overflow-hidden rounded-[2rem] aspect-[3/4.2] group cursor-pointer shadow-lg hover:shadow-xl transition-all duration-500 flex flex-col justify-end p-6 bg-black/10">
          <!-- Imagen de fondo texturada -->
          <img 
            src="/img/tableta1.png" 
            alt="Ingredientes de Origen Noble" 
            class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:scale-105 transition-transform duration-700 pointer-events-none" 
          />
          <!-- Overlay degradado oscuro gradual -->
          <div class="absolute inset-0 bg-gradient-to-t from-[#1A0A0C]/90 via-[#1A0A0C]/35 to-transparent z-0 transition-opacity duration-500"></div>
          <!-- Overlay café en hover -->
          <div class="absolute inset-0 bg-[#2A1612] opacity-0 group-hover:opacity-85 z-0 transition-opacity duration-500"></div>
          
          <!-- Contenido en la base -->
          <div class="relative z-10 flex flex-col items-start text-left text-white">
            <!-- Icono blanco -->
            <div class="w-12 h-12 rounded-full bg-white/10 backdrop-blur-md flex items-center justify-center mb-4 text-[#f6d98d] group-hover:bg-[#8f6c49]/80 group-hover:text-white transition-all duration-500">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.58 1 9.3a7 7 0 0 1-9 8.7z" />
                <path d="M9 22v-4" />
              </svg>
            </div>
            
            <h3 class="font-serif font-bold text-lg md:text-xl text-white mb-2 leading-tight">Origen Noble</h3>
            
            <!-- Descripción que se despliega elegantemente en hover -->
            <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-all duration-500 ease-in-out">
              <p class="overflow-hidden text-[11px] text-white/80 leading-relaxed font-sans transition-all duration-500">
                Privilegiamos la pureza de nuestros componentes. Al utilizar ingredientes auténticos y naturales, logramos realzar las notas aromáticas del cacao, ofreciendo una experiencia genuina y superior en cada bocado.
              </p>
            </div>
          </div>
        </div>

        <!-- Tarjeta 4: Sofisticación en Cada Detalle -->
        <div class="relative overflow-hidden rounded-[2rem] aspect-[3/4.2] group cursor-pointer shadow-lg hover:shadow-xl transition-all duration-500 flex flex-col justify-end p-6 bg-black/10">
          <!-- Imagen de fondo texturada -->
          <img 
            src="/img/razon1.png" 
            alt="Sofisticación en Cada Detalle" 
            class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:scale-105 transition-transform duration-700 pointer-events-none" 
          />
          <!-- Overlay degradado oscuro gradual -->
          <div class="absolute inset-0 bg-gradient-to-t from-[#1A0A0C]/90 via-[#1A0A0C]/35 to-transparent z-0 transition-opacity duration-500"></div>
          <!-- Overlay café en hover -->
          <div class="absolute inset-0 bg-[#2A1612] opacity-0 group-hover:opacity-85 z-0 transition-opacity duration-500"></div>
          
          <!-- Contenido en la base -->
          <div class="relative z-10 flex flex-col items-start text-left text-white">
            <!-- Icono blanco -->
            <div class="w-12 h-12 rounded-full bg-white/10 backdrop-blur-md flex items-center justify-center mb-4 text-[#f6d98d] group-hover:bg-[#8f6c49]/80 group-hover:text-white transition-all duration-500">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 3h12l4 6-10 13L2 9z" />
                <path d="M11 3 8 9l4 13 4-13-3-6" />
                <path d="M2 9h20" />
              </svg>
            </div>
            
            <h3 class="font-serif font-bold text-lg md:text-xl text-white mb-2 leading-tight">Sofisticación</h3>
            
            <!-- Descripción que se despliega elegantemente en hover -->
            <div class="grid grid-rows-[0fr] group-hover:grid-rows-[1fr] transition-all duration-500 ease-in-out">
              <p class="overflow-hidden text-[11px] text-white/80 leading-relaxed font-sans transition-all duration-500">
                Más que un chocolate, ofrecemos una experiencia sensorial completa. Nuestras líneas de presentación reflejan una elegancia indiscutible, convirtiendo cada producto en una obra de arte digna de ser compartida y admirada.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCIÓN COMUNIDAD TABOADA (ESTILO MODERNO INSPIRADO EN NUEVA REFERENCIA CON FOTOS SUPERPUESTAS Y 4 MÉTRICAS INFERIORES) -->
  <section class="relative py-20 md:py-28 overflow-hidden bg-[#FAF5F0] border-b border-[#e8dccb]/50 text-[#2A1612]">
    
    <!-- Imagen de fondo fondo1.png elegante con degradado sutil sin bordes grises -->
    <div 
      class="absolute inset-0 bg-cover bg-center opacity-15 pointer-events-none mix-blend-multiply"
      style="background-image: url('/img/fondo1.png'); mask-image: radial-gradient(ellipse at center, black 65%, transparent 98%); -webkit-mask-image: radial-gradient(ellipse at center, black 65%, transparent 98%);"
    ></div>

    <!-- Brillo dorado sutil de fondo -->
    <div class="absolute -left-1/4 top-1/4 w-[600px] h-[600px] rounded-full bg-[#8f6c49]/5 blur-[120px] pointer-events-none"></div>
    <div class="absolute -right-1/4 bottom-1/4 w-[600px] h-[600px] rounded-full bg-[#8f6c49]/5 blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
      
      <!-- GRID SUPERIOR (2 COLUMNAS): FOTOS SUPERPUESTAS Y LISTA VERTICAL DE BENEFICIOS -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        
        <!-- LADO IZQUIERDO (cols 1-6): Composición de 2 Fotos Superpuestas + Insignia Circular Flotante -->
        <div class="lg:col-span-6 flex justify-center relative">
          <div class="relative w-full max-w-[460px] h-[400px] sm:h-[460px]">
            
            <!-- 1. Foto Principal Grande (Atras / Derecha) -->
            <div class="absolute top-0 right-0 w-[72%] h-[85%] rounded-[2.5rem] overflow-hidden shadow-xl border-4 border-white z-10 bg-[#2A1612]">
              <img 
                src="/img/comunidad_degustacion.jpg" 
                alt="Comunidad Taboada Degustación" 
                class="w-full h-full object-cover object-center transform hover:scale-105 transition-transform duration-700"
              />
            </div>

            <!-- 2. Foto Secundaria Superpuesta (Adelante / Izquierda Abajo) -->
            <div class="absolute bottom-0 left-0 w-[62%] h-[68%] rounded-[2.2rem] overflow-hidden shadow-2xl border-4 border-white z-20 bg-[#2A1612]">
              <img 
                src="/img/sucursal_interior.png" 
                alt="Interior Chocolatería Taboada" 
                class="w-full h-full object-cover object-center transform hover:scale-105 transition-transform duration-700"
              />
            </div>

            <!-- 3. Insignia Circular Flotante en la Intersección (Estilo Púrpura/Dorado del Mockup) -->
            <div class="absolute bottom-[22%] left-[45%] -translate-x-1/2 w-24 h-24 sm:w-28 sm:h-28 rounded-full bg-gradient-to-tr from-[#2A1612] to-[#42221b] text-[#dcb041] flex flex-col items-center justify-center border-4 border-white shadow-2xl z-30 transform hover:scale-110 transition-transform duration-300">
              <span class="text-lg sm:text-xl font-extrabold font-serif text-[#dcb041] leading-none">1,500+</span>
              <span class="text-[9px] font-bold text-[#FAF5F0] uppercase tracking-wider mt-1 text-center px-1">Miembros VIP</span>
            </div>

          </div>
        </div>

        <!-- LADO DERECHO (cols 7-12): Encabezado y Beneficios Verticales con Iconos Circulares -->
        <div class="lg:col-span-6 flex flex-col items-start text-left lg:pl-4">
          
          <!-- Eyebrow -->
          <div class="flex items-center gap-2 mb-3">
            <span class="w-8 h-[2px] bg-[#8f6c49]"></span>
            <span class="text-xs md:text-sm uppercase tracking-widest text-[#8f6c49] font-extrabold font-sans">
              Programa de Lealtad
