---

<Layout
  title="El sabor de la tradición | Chocolates Taboada"
  description="Descubre Chocolates Taboada, la primera industria chocolatera de Bolivia desde 1948. Tradición, elegancia y un sabor inolvidable."
>
  <nav
    class="fixed top-0 left-0 w-full z-[999] transition-all duration-500
         bg-white/5 backdrop-blur-[14px] border-b border-white/10
         hover:bg-white/10"
  >
    <!-- Contenedor flex principal -->
    <div class="flex items-stretch justify-between h-[85px] md:h-[100px] w-full relative overflow-visible">
      
      <!-- LADO IZQUIERDO (Logo + Links) -->
      <div class="flex items-center pl-5 lg:pl-10 relative z-10">
        <a href="/">
          <img
            src="/img/taboada-logo.png"
            alt="Taboada"
            class="object-contain drop-shadow-[0_4px_14px_rgba(0,0,0,0.18)]
                 h-[55px] md:h-[75px]
                 transition-all duration-500"
          />
        </a>

        <!-- Enlaces de Navegación (tipo el mockup) -->
        <div class="hidden md:flex items-center gap-6 lg:gap-8 ml-10">
          <a
            href="#inicio"
            class="text-white/80 hover:text-[#dcb041] font-bold text-sm tracking-wide transition-all duration-300"
          >
            Inicio
          </a>
          <a
            href="#cajas-especiales"
            class="text-white/80 hover:text-[#dcb041] font-bold text-sm tracking-wide transition-all duration-300"
          >
            Colecciones
          </a>
          <a
            href="/beneficios"
            class="text-white/80 hover:text-[#dcb041] font-bold text-sm tracking-wide transition-all duration-300"
          >
            Beneficios
          </a>
          <a
            href="/adulto-mayor"
            class="text-white/80 hover:text-[#dcb041] font-bold text-sm tracking-wide transition-all duration-300"
          >
            Adulto Mayor
          </a>
        </div>
      </div>

      <!-- LADO DERECHO (Fondo café inclinado y Selector de Ciudad) -->
      <div class="flex items-center pr-5 lg:pr-10 pl-16 md:pl-24 relative overflow-visible">
        
        <!-- Fondo Café Sesgado (Detrás de los elementos pero dentro de este contenedor) -->
        <div 
          class="absolute inset-0 bg-gradient-to-r from-[#3D1C16]/95 to-[#210D0A]/95 z-0 transition-all duration-500"
          style="clip-path: polygon(3.5rem 0, 100% 0, 100% 100%, 0 100%); margin-left: -3.5rem;"
        ></div>

        <!-- Elementos del Lado Derecho (Ciudad) -->
        <div class="relative z-10 flex items-center overflow-visible">
          
          <!-- SELECTOR DE UBICACIÓN -->
          <div class="relative inline-block text-left z-[1000] overflow-visible">
            <button
              id="city-selector-btn"
              type="button"
              class="flex items-center gap-1.5 px-4 py-2 md:px-5 md:py-2.5 text-xs md:text-sm font-bold rounded-full bg-white text-[#3D1C16] hover:bg-[#FAF0E6] transition-all duration-300 cursor-pointer shadow-[0_4px_15px_rgba(0,0,0,0.25)] hover:scale-[1.03]"
            >
              <svg class="w-4 h-4 text-[#dcb041]" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"></path>
              </svg>
              <span id="active-city-name">Detectando...</span>
              <span class="text-[8px] opacity-70">▼</span>
            </button>
            
            <!-- MENU DESPLEGABLE -->
            <div
              id="city-dropdown"
              class="hidden absolute right-0 mt-2 w-44 rounded-2xl bg-[#2b0f17]/95 border border-white/10 shadow-2xl backdrop-blur-md overflow-hidden transition-all duration-300"
            >
              <button data-city="cochabamba" class="city-opt-btn w-full px-4 py-3 text-left text-xs text-white hover:bg-[#dcb041] hover:text-[#2e1119] transition-colors duration-250 cursor-pointer block font-semibold border-b border-white/5">📍 Cochabamba</button>
              <button data-city="la-paz" class="city-opt-btn w-full px-4 py-3 text-left text-xs text-white hover:bg-[#dcb041] hover:text-[#2e1119] transition-colors duration-250 cursor-pointer block font-semibold">📍 La Paz</button>
            </div>
          </div>

        </div>

      </div>

    </div>
  </nav>

  <header
    id="inicio"
    class="relative min-h-screen overflow-hidden bg-[#14080d]"
  >
    <div
      id="hero-bg-cover"
      class="absolute inset-0 bg-no-repeat
           bg-cover bg-[position:80%_center] scale-100
           lg:bg-center lg:scale-105 transition-all duration-700"
      style="background-image:url('/img/taboadaportada.png')"
    >
    </div>

    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,rgba(10,5,7,0.96)_0%,rgba(20,10,15,0.92)_20%,rgba(38,18,25,0.82)_42%,rgba(62,28,40,0.58)_68%,rgba(120,70,85,0.18)_88%,rgba(255,255,255,0)_100%)]"
    >
    </div>

    <!-- BRILLO PREMIUM -->

    <div
      class="absolute top-[-180px] left-[-120px] w-[500px] h-[500px] rounded-full bg-[#f6d98d]/10 blur-[120px]"
    >
    </div>

    <!-- PARTICULAS -->

    <div class="absolute inset-0 overflow-hidden z-[2]">
      <!-- LUCES -->

      <span
        class="absolute top-[52%] left-[20%] w-2 h-2 rounded-full bg-[#F6D983] shadow-[0_0_20px_rgba(255,220,120,0.9)] animate-float"
      ></span>

      <span
        class="absolute top-[48%] left-[34%] w-1 h-1 rounded-full bg-[#F6D983] shadow-[0_0_20px_rgba(255,220,120,0.9)] animate-float [animation-delay:1s]"
      ></span>

      <span
        class="absolute top-[58%] left-[48%] w-2 h-2 rounded-full bg-[#F6D983] shadow-[0_0_20px_rgba(255,220,120,0.9)] animate-float [animation-delay:2s]"
      ></span>

      <span
        class="absolute top-[66%] left-[64%] w-1.5 h-1.5 rounded-full bg-[#F6D983] shadow-[0_0_20px_rgba(255,220,120,0.9)] animate-float [animation-delay:3s]"
      ></span>

      <!-- PETALOS (SVG inline) -->

      <!-- CHOCOLATE Y CACAO FALL (SVGs) -->
      <svg class="chocolate-fall absolute left-[5%] w-3 opacity-60" style="animation-duration:9s; animation-delay:2.5s;" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="5" cy="5" r="4" fill="#3D1C06" /></svg>
      <svg class="chocolate-fall absolute left-[12%] w-7 opacity-75" style="animation-duration:14s; animation-delay:0s;" viewBox="0 0 40 60" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20,10 C32,20 32,40 20,50 C8,40 8,20 20,10 Z" fill="#3D1C06" /><path d="M20,15 C24,22 24,38 20,45" stroke="#D4AF37" stroke-width="1.5" stroke-linecap="round" opacity="0.6" /></svg>
      <svg class="chocolate-fall absolute left-[22%] w-5 opacity-60" style="animation-duration:9s; animation-delay:1s;" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15,5 L17,12 L24,15 L17,18 L15,25 L13,18 L6,15 L13,12 Z" fill="#2A1612" /></svg>
      <svg class="chocolate-fall absolute left-[33%] w-5 opacity-65" style="animation-duration:13s; animation-delay:6s;" viewBox="0 0 40 60" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20,15 C28,23 28,37 20,45 C12,37 12,23 20,15 Z" fill="#42200D" /></svg>
      <svg class="chocolate-fall absolute left-[45%] w-8 opacity-80" style="animation-duration:11s; animation-delay:3s;" viewBox="0 0 40 60" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20,12 C30,22 30,38 20,48 C10,38 10,22 20,12 Z" fill="#5C3821" /><path d="M20,17 C23,24 23,36 20,43" stroke="#F6D98D" stroke-width="1.2" stroke-linecap="round" opacity="0.5" /></svg>
      <svg class="chocolate-fall absolute left-[53%] w-4 opacity-60" style="animation-duration:12s; animation-delay:5s;" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><polygon points="10,3 17,7 15,15 7,17 3,10" fill="#2E160A" /></svg>
      <svg class="chocolate-fall absolute left-[62%] w-4 opacity-75" style="animation-duration:8s; animation-delay:4s;" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15,7 L17,12 L22,15 L17,18 L15,23 L13,18 L8,15 L13,12 Z" fill="#D4AF37" /></svg>
      <svg class="chocolate-fall absolute left-[70%] w-3 opacity-80" style="animation-duration:7s; animation-delay:0.5s;" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="5" cy="5" r="4" fill="#D4AF37" /></svg>
      <svg class="chocolate-fall absolute left-[78%] w-6 opacity-70" style="animation-duration:16s; animation-delay:1.5s;" viewBox="0 0 40 60" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20,10 C32,20 32,40 20,50 C8,40 8,20 20,10 Z" fill="url(#goldGrad)" /><defs><linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#D4AF37" /><stop offset="50%" stop-color="#F6D98D" /><stop offset="100%" stop-color="#AA7C11" /></linearGradient></defs></svg>
      <svg class="chocolate-fall absolute left-[88%] w-5 opacity-70" style="animation-duration:10s; animation-delay:2s;" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15,5 L17,12 L24,15 L17,18 L15,25 L13,18 L6,15 L13,12 Z" fill="#7A4B29" /></svg>
      <svg class="chocolate-fall absolute left-[93%] w-2.5 opacity-75" style="animation-duration:8s; animation-delay:7s;" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="5" cy="5" r="4" fill="#F6D98D" /></svg>
    </div>

    <!-- CONTENIDO -->

    <div
      class="relative z-[5] w-full max-w-[1440px] mx-auto min-h-screen px-6 lg:pl-16 lg:pr-10 pt-[120px] pb-20 grid lg:grid-cols-2 items-center gap-8"
    >
      <!-- TEXTO -->

      <div class="max-w-[500px]">
        <!-- MINI TEXTO -->

        <div class="flex items-center gap-4 mb-6">
          <div
            class="w-10 h-[1px] bg-gradient-to-r from-[#f6d98d] to-transparent"
          >
          </div>

          <span
            class="uppercase tracking-[0.38em] text-[#f6d98d] text-[0.72rem] font-semibold"
          >
            TRADICIÓN DESDE 1948
          </span>
        </div>

        <!-- TITULO -->

        <h1
          class="font-playfair text-[clamp(3.2rem,6.5vw,5.5rem)] leading-[0.92] tracking-[-0.06em] text-[#fff7f8] drop-shadow-[0_12px_35px_rgba(0,0,0,0.45)]"
        >
          Tradición<br />

          <span class="text-[#f6d98d] italic font-[600]"> que deleita </span>
        </h1>

        <!-- TEXTO -->

        <p
          class="mt-6 text-[clamp(0.95rem,1.5vw,1.1rem)] leading-[1.8] text-[#f3dfe5]/75 max-w-[460px] font-light"
        >
          Disfruta del auténtico chocolate boliviano con más de siete décadas de historia.
          Elaborado con la más fina selección de cacao de nuestra tierra, manteniendo 
          recetas tradicionales de generación en generación.
        </p>

        <!-- BOTONES -->

        <div class="mt-10 flex flex-wrap items-center gap-3.5">
          <a
            href="#cajas-especiales"
            class="group inline-flex items-center gap-2.5 px-7 py-4 rounded-full bg-[linear-gradient(145deg,#f6d98d,#dcb041)] text-[#2e1119] font-bold text-xs md:text-sm shadow-[0_10px_25px_rgba(220,176,65,0.2)] hover:scale-[1.03] transition-all duration-500 relative overflow-hidden"
          >
            <span class="relative z-10 tracking-wide">✦ Descúbrelo aquí</span>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/60 to-transparent -translate-x-[130%] group-hover:animate-shimmer"></div>
          </a>

          <a
            href="/beneficios"
            class="group inline-flex items-center gap-2.5 px-7 py-4 rounded-full border border-warm-white/35 bg-warm-white/12 text-warm-white font-bold text-xs md:text-sm hover:scale-[1.03] hover:bg-warm-white/20 transition-all duration-500 relative overflow-hidden"
          >
            <span class="relative z-10 tracking-wide">Canjear Beneficios</span>
          </a>
        </div>
      </div>
    </div>
  </header>

  <section class="relative py-20 md:py-24 bg-[#FAF5F0] overflow-hidden border-y border-[#f0e6d8]">
    <!-- Sutil brillo decorativo de fondo -->
    <div class="absolute -right-20 top-1/2 -translate-y-1/2 w-48 h-48 bg-gradient-radial from-amber-200/10 to-transparent blur-3xl pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
      
      <!-- CABECERA: Título a la izquierda, Introducción y Botón a la derecha -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16 items-center">
        
        <!-- Lado Izquierdo: Categoría y Título principal -->
        <div class="lg:col-span-7 text-left">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-6 h-[2px] bg-[#8f6c49]"></span>
            <span class="text-xs uppercase tracking-widest text-[#8f6c49] font-bold font-sans">Nuestra Propuesta</span>
          </div>
          <h2 class="font-serif text-3xl md:text-5xl text-[#2A1612] font-extrabold leading-tight tracking-tight">
            Calidad y elegancia <br />
