---

<Layout
  title="El sabor de la tradición | Chocolates Taboada"
  description="Descubre Chocolates Taboada, la primera industria chocolatera de Bolivia desde 1948. Tradición, elegancia y un sabor inolvidable."
>
  <nav
    class="fixed top-0 left-0 w-full z-[999] transition-all duration-500
         bg-white/8 backdrop-blur-[14px] border-b border-white/10
         hover:bg-[#2b0f17]/70"
  >
    <div class="w-[min(1350px,100%)] mx-auto px-5 lg:px-10">
      <!-- NAV -->

      <div
        class="flex items-center justify-between
             h-[95px] md:h-[110px]
             transition-all duration-500"
      >
        <!-- LOGO -->

        <div class="flex items-center gap-4">
          <a href="/">
            <img
              src="/img/taboada-logo.png"
              alt="Taboada"
              class="object-contain drop-shadow-[0_4px_14px_rgba(0,0,0,0.18)]
                   h-[65px] md:h-[90px]
                   transition-all duration-500"
            />
          </a>

          <!-- SELECTOR DE UBICACIÓN -->
          <div class="relative inline-block text-left z-[1000]">
            <button
              id="city-selector-btn"
              type="button"
              class="flex items-center gap-1.5 px-3 py-1.5 md:px-4 md:py-2 text-[10px] md:text-xs font-semibold rounded-full border border-white/20 bg-white/10 text-white hover:bg-white/20 transition-all duration-300 cursor-pointer"
            >
              <svg class="w-3.5 h-3.5 text-[#f6d98d]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"></path>
              </svg>
              <span id="active-city-name">Detectando...</span>
              <span class="text-[8px] opacity-70">▼</span>
            </button>
            
            <!-- MENU DESPLEGABLE -->
            <div
              id="city-dropdown"
              class="hidden absolute left-0 mt-2 w-40 rounded-2xl bg-[#2b0f17]/95 border border-white/10 shadow-2xl backdrop-blur-md overflow-hidden transition-all duration-300"
            >
              <button data-city="cochabamba" class="city-opt-btn w-full px-4 py-2.5 text-left text-xs text-white hover:bg-[#dcb041] hover:text-[#2e1119] transition-colors duration-250 cursor-pointer block font-medium">📍 Cochabamba</button>
              <button data-city="la-paz" class="city-opt-btn w-full px-4 py-2.5 text-left text-xs text-white hover:bg-[#dcb041] hover:text-[#2e1119] transition-colors duration-250 cursor-pointer block font-medium">📍 La Paz</button>
            </div>
          </div>
        </div>

        <!-- BOTONES -->

        <div class="flex items-center gap-3">
          <a
            href="#elegancia"
            class="group hidden sm:inline-flex items-center gap-3
                 px-5 py-3 sm:px-7 sm:py-4 text-sm sm:text-[0.95rem]
                 rounded-full
                 bg-[linear-gradient(145deg,#F4D6C8,#EAC0B4)]
                 text-[#5B2A22]
                 font-bold
                 shadow-[0_15px_35px_rgba(255,220,200,0.35)]
                 hover:scale-[1.03]
                 transition-all duration-500
                 relative overflow-hidden"
          >
            <span class="relative z-10">Ver regalos destacados</span>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/60 to-transparent -translate-x-[130%] group-hover:animate-shimmer"></div>
          </a>

          <a
            href="/beneficios"
            class="group inline-flex items-center gap-3
                 px-5 py-3 sm:px-7 sm:py-4 text-sm sm:text-[0.95rem]
                 rounded-full
                 bg-[linear-gradient(145deg,#f6d98d,#dcb041)]
                 text-[#2e1119]
                 font-bold
                 shadow-[0_15px_35px_rgba(220,176,65,0.35)]
                 hover:scale-[1.03]
                 transition-all duration-500
                 relative overflow-hidden"
          >
            <span class="relative z-10">Mis Beneficios</span>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/60 to-transparent -translate-x-[130%] group-hover:animate-shimmer"></div>
          </a>
        </div>
      </div>
    </div>
  </nav>

  <header
