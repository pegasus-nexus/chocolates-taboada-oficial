  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Selectores de Categorías
      const catButtons = [];
      const cards = [];
      const noProductsMsg = null;

      // Selectores de Ubicación
      const citySelectorBtn = document.getElementById('city-selector-btn');
      const cityDropdown = document.getElementById('city-dropdown');
      const activeCityName = document.getElementById('active-city-name');
      const cityOptButtons = document.querySelectorAll('.city-opt-btn');
      const bgOverlay = document.getElementById('cajas-especiales-bg');
      const heroBgCover = document.getElementById('hero-bg-cover');

      // Selectores de Ver Más
      const seeMoreContainer = null;
      const seeMoreBtn = null;

      // Estados actuales
      let currentCategory = 'todo';
      let currentCity = 'cochabamba'; // Valor inicial / fallback
      let isExpanded = false; // Estado del botón Ver Más

      // ── DROPDOWN SELECTOR DE UBICACIÓN ──
      citySelectorBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        cityDropdown?.classList.toggle('hidden');
      });

      document.addEventListener('click', () => {
        cityDropdown?.classList.add('hidden');
      });

      // ── MENÚ MÓVIL (DRAWER) ──
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileCloseBtn = document.getElementById('mobile-close-btn');
      const mobileDrawer = document.getElementById('mobile-drawer');
      const drawerOverlay = document.getElementById('drawer-overlay');
      const mobileLinks = document.querySelectorAll('.mobile-link');

      function openDrawer() {
        mobileDrawer?.classList.remove('translate-x-full');
        drawerOverlay?.classList.remove('opacity-0', 'pointer-events-none');
      }

      function closeDrawer() {
        mobileDrawer?.classList.add('translate-x-full');
        drawerOverlay?.classList.add('opacity-0', 'pointer-events-none');
      }

      mobileMenuBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        openDrawer();
      });

      mobileCloseBtn?.addEventListener('click', closeDrawer);
      drawerOverlay?.addEventListener('click', closeDrawer);

      mobileLinks.forEach((link) => {
        link.addEventListener('click', closeDrawer);
      });

      // ── ACTUALIZAR CIUDAD SELECCIONADA ──
      function updateCity(city: string) {
        currentCity = city;
        localStorage.setItem('selected_city', city);
        window.dispatchEvent(new CustomEvent('cityChanged', { detail: { city } }));

        // Actualizar etiqueta del botón
        if (activeCityName) {
          activeCityName.textContent = city === 'cochabamba' ? 'Cochabamba' : 'La Paz';
        }

        // Inyectar clase al document.body (Para manejo CSS global si es necesario)
        document.body.classList.remove('city-cochabamba', 'city-lapaz', 'city-la-paz');
        document.body.classList.add(`city-${city}`);

        // Actualizar la portada del Hero con una transición (Fade Out / Fade In)
        if (heroBgCover) {
          const bgCbba = heroBgCover.getAttribute('data-bg-cochabamba') || '/img/portadataboada.png';
          const bgLpz = heroBgCover.getAttribute('data-bg-lapaz') || '/img/portadalapaz.png';
          
          heroBgCover.style.opacity = '0'; // Disparar fade-out
          
          setTimeout(() => {
            if (city === 'cochabamba') {
              heroBgCover.style.backgroundImage = `url('${bgCbba}')`;
            } else if (city === 'la-paz') {
              heroBgCover.style.backgroundImage = `url('${bgLpz}')`;
            }
            heroBgCover.style.opacity = '1'; // Disparar fade-in tras aplicar nueva imagen
          }, 400); // 400ms para sincronizarse con la transición CSS
        }

        // Actualizar el degradado de fondo de Colecciones
        if (bgOverlay) {
          // Remover clases viejas de gradientes
          bgOverlay.classList.remove(
            'from-[#FAF5F0]', 'via-[#F3ECE3]', 'to-[#FAF5F0]',
            'from-[#FAF6F2]', 'via-[#EADCD0]', 'to-[#FAF6F2]',
            'from-[#FAF7F5]', 'via-[#E2DFD8]', 'to-[#FAF7F5]'
          );
          
          // Añadir clases nuevas basadas en la ciudad y aplicar transición
          bgOverlay.style.transition = 'all 0.6s ease-in-out';
          if (city === 'cochabamba') {
            bgOverlay.classList.add('from-[#FAF6F2]', 'via-[#EADCD0]', 'to-[#FAF6F2]');
          } else if (city === 'la-paz') {
            bgOverlay.classList.add('from-[#FAF7F5]', 'via-[#E2DFD8]', 'to-[#FAF7F5]');
          }
        }

        // Refrescar el filtrado de productos y los precios
        // filterProducts();
      }

      // ── FILTRAR PRODUCTOS Y PRECIOS ──
      function filterProducts() {
        let matchingCards: Element[] = [];

        // 1. Clasificar tarjetas que coinciden con los filtros activos
        cards.forEach((card) => {
          const categoriesAttr = card.getAttribute('data-categories') || '';
          const categoriesList = categoriesAttr.split(' ');
          const availableAttr = card.getAttribute('data-available') || '';
          const availableList = availableAttr.split(' ');

          const matchesCategory = currentCategory === 'todo' || categoriesList.includes(currentCategory);
          const matchesCity = availableList.includes(currentCity);

          // Actualizar el precio dinámicamente antes de mostrar/ocultar
          const priceLabel = card.querySelector('.product-price-label');
          if (priceLabel) {
            const priceKey = currentCity === 'cochabamba' ? 'data-price-cochabamba' : 'data-price-lapaz';
            priceLabel.textContent = card.getAttribute(priceKey) || '';
          }

          if (matchesCategory && matchesCity) {
            matchingCards.push(card);
          } else {
            card.classList.add('hidden');
          }
        });

        // 2. Gestionar la visualización del botón "Ver más"
        const limit = 4;
        if (matchingCards.length > limit) {
          seeMoreContainer?.classList.remove('hidden');
          if (seeMoreBtn) {
            seeMoreBtn.textContent = isExpanded ? 'Ver menos' : 'Ver más';
          }

          matchingCards.forEach((card, index) => {
            if (isExpanded || index < limit) {
              card.classList.remove('hidden');
              // Pequeña animación de entrada
              (card as HTMLElement).style.opacity = '0';
              setTimeout(() => {
                (card as HTMLElement).style.opacity = '1';
                (card as HTMLElement).style.transition = 'opacity 0.4s ease, transform 0.4s ease';
              }, 30);
            } else {
              card.classList.add('hidden');
            }
          });
        } else {
          // Ocultar botón si hay 4 o menos productos y mostrarlos todos
          seeMoreContainer?.classList.add('hidden');
          matchingCards.forEach((card) => {
            card.classList.remove('hidden');
            (card as HTMLElement).style.opacity = '0';
            setTimeout(() => {
              (card as HTMLElement).style.opacity = '1';
              (card as HTMLElement).style.transition = 'opacity 0.4s ease, transform 0.4s ease';
            }, 30);
          });
        }

        // Mostrar u ocultar mensaje vacío
        if (matchingCards.length === 0) {
          noProductsMsg?.classList.remove('hidden');
        } else {
          noProductsMsg?.classList.add('hidden');
        }
      }

      // Clic en Ver Más / Ver Menos
      seeMoreBtn?.addEventListener('click', () => {
        isExpanded = !isExpanded;
        // filterProducts();
      });

      // Clics en opciones de ciudades
      cityOptButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const selected = btn.getAttribute('data-city') || 'cochabamba';
          isExpanded = false; // Resetear expansión
          updateCity(selected);
        });
      });

      // ── LÓGICA DE COLAPSAR/GUARDAR BARRA LATERAL DE CATEGORÍAS ──
      const catSidebar = document.getElementById('cat-sidebar');
      const toggleSidebarBtn = document.getElementById('toggle-cat-sidebar-btn');
      const arrowIcon = document.getElementById('cat-sidebar-arrow-icon');
      const headerTitle = document.getElementById('cat-sidebar-header-title');
      const productGridColumn = document.getElementById('product-grid-column');

      toggleSidebarBtn?.addEventListener('click', () => {
        const isCollapsed = catSidebar?.classList.contains('is-collapsed-sidebar');

        if (isCollapsed) {
          // EXPANDIR
          catSidebar?.classList.remove('is-collapsed-sidebar');
          catSidebar?.classList.remove('lg:col-span-1', 'lg:w-[70px]');
          catSidebar?.classList.add('lg:col-span-2', 'w-full');
          
          productGridColumn?.classList.remove('lg:col-span-11');
          productGridColumn?.classList.add('lg:col-span-10');

          if (arrowIcon) arrowIcon.style.transform = 'rotate(0deg)';
          if (headerTitle) headerTitle.style.display = '';

          document.querySelectorAll('.cat-btn-label').forEach(el => (el as HTMLElement).style.display = '');
          document.querySelectorAll('.cat-btn').forEach(btn => {
            btn.classList.remove('justify-center');
            btn.classList.add('gap-2.5');
          });
        } else {
          // COLAPSAR / GUARDAR (MODO SOLO ÍCONOS)
          catSidebar?.classList.add('is-collapsed-sidebar');
          catSidebar?.classList.remove('lg:col-span-2', 'w-full');
          catSidebar?.classList.add('lg:col-span-1', 'lg:w-[70px]');
          
          productGridColumn?.classList.remove('lg:col-span-10');
          productGridColumn?.classList.add('lg:col-span-11');

          if (arrowIcon) arrowIcon.style.transform = 'rotate(180deg)';
          if (headerTitle) headerTitle.style.display = 'none';

          document.querySelectorAll('.cat-btn-label').forEach(el => (el as HTMLElement).style.display = 'none');
          document.querySelectorAll('.cat-btn').forEach(btn => {
            btn.classList.add('justify-center');
            btn.classList.remove('gap-2.5');
          });
        }
      });

      // Clics en botones de categorías
      catButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          currentCategory = btn.getAttribute('data-target') || 'todo';
          isExpanded = false; // Resetear expansión

          // Actualizar estilos de los botones de categoría
          catButtons.forEach((b) => {
            b.classList.remove('bg-[#2A1612]', 'text-[#dcb041]', 'shadow-sm', 'border-[#2A1612]');
            b.classList.add('text-[#5D4037]', 'hover:bg-[#FAF0E6]', 'hover:text-[#2A1612]');
          });

          btn.classList.add('bg-[#2A1612]', 'text-[#dcb041]', 'shadow-sm', 'border', 'border-[#2A1612]');
          btn.classList.remove('text-[#5D4037]', 'hover:bg-[#FAF0E6]', 'hover:text-[#2A1612]');

          // filterProducts();
        });
      });

      // ── INICIALIZACIÓN Y DETECCIÓN POR IP SILENCIOSA ──
      const savedCity = localStorage.getItem('selected_city');
      if (savedCity && (savedCity === 'cochabamba' || savedCity === 'la-paz')) {
        updateCity(savedCity);
      } else {
        // Petición silenciosa asíncrona a ipapi.co/json/ (HTTPS)
        fetch('https://ipapi.co/json/')
          .then((res) => {
            if (res.ok) return res.json();
            throw new Error('API Response Error');
          })
          .then((data) => {
            console.log('Ciudad detectada por API:', data.city);
            
            const cityValue = (data.city || '').toLowerCase();
            const regionValue = (data.region || '').toLowerCase();
            
            // Evaluación estricta única y exclusivamente de los campos city y region (ignora timezone)
            const detected = (cityValue.includes('paz') || regionValue.includes('paz')) ? 'la-paz' : 'cochabamba';
            updateCity(detected);
          })
          .catch((err) => {
            // Manejo silencioso de errores para evitar romper la carga (AdBlockers o fallos de red)
            updateCity('cochabamba');
          });
      }

      // ── DETECTAR Y FILTRAR POR PARÁMETROS URL (?cat=...) ──
      function checkUrlParams() {
        const urlParams = new URLSearchParams(window.location.search);
        const catParam = urlParams.get('cat');
        if (catParam) {
          const targetBtn = document.querySelector(`.cat-btn[data-target="${catParam}"]`) as HTMLButtonElement;
          if (targetBtn) {
            setTimeout(() => {
              targetBtn.click();
              const targetSection = document.getElementById('cajas-especiales');
              if (targetSection) {
                targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
              }
            }, 300);
          }
        }
      }

      checkUrlParams();

      // Interceptar clicks en enlaces del menu dropdown cuando estamos en el home
      const dropdownLinks = document.querySelectorAll('a[href*="?cat="]');
      dropdownLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          const hrefAttr = link.getAttribute('href') || '';
          const isHomePage = window.location.pathname === '/' || window.location.pathname === '/index.html' || window.location.pathname === '';
          if (isHomePage) {
            const url = new URL(hrefAttr, window.location.href);
            const cat = url.searchParams.get('cat');
            if (cat) {
              const targetBtn = document.querySelector(`.cat-btn[data-target="${cat}"]`) as HTMLButtonElement;
              if (targetBtn) {
                e.preventDefault();
                targetBtn.click();
                const targetSection = document.getElementById('cajas-especiales');
                if (targetSection) {
                  targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
                // Limpiar la query de la URL sin recargar
                window.history.pushState({}, '', window.location.pathname);
              }
            }
          }
        });
      });

      // ── LOGICA COMPLETA DEL CARRITO DE COMPRAS ──
      let cart = JSON.parse(localStorage.getItem('taboada_cart') || '[]');
      
      // Selectores Modal de Cantidad
      const qtyModal = document.getElementById('quantity-modal');
      const qtyModalOverlay = document.getElementById('quantity-modal-overlay');
      const qtyModalClose = document.getElementById('quantity-modal-close');
      const modalProdName = document.getElementById('modal-product-name');
      const modalProdSize = document.getElementById('modal-product-size');
      const modalProdImg = document.getElementById('modal-product-img') as HTMLImageElement;
      const modalQtyVal = document.getElementById('modal-qty-val');
      const modalQtyMinus = document.getElementById('modal-qty-minus');
      const modalQtyPlus = document.getElementById('modal-qty-plus');
      const modalTotalPrice = document.getElementById('modal-total-price');
      const modalAddBtn = document.getElementById('modal-add-btn');

      // Selectores Drawer Carrito
      const cartDrawer = document.getElementById('cart-drawer');
      const cartOverlay = document.getElementById('cart-overlay');
      const cartDrawerClose = document.getElementById('cart-drawer-close');
      const floatingCartBtn = document.getElementById('floating-cart-btn');
      const cartCountBadge = document.getElementById('cart-count-badge');
      const cartItemsList = document.getElementById('cart-items-list');
      const cartEmptyMsg = document.getElementById('cart-empty-msg');
      const cartTotalPrice = document.getElementById('cart-total-price');
      const cartCheckoutBtn = document.getElementById('cart-checkout-btn');

      // Variables de control del Modal
      let modalActiveProduct = {
        name: '',
        size: '',
        img: '',
        price: 0,
        quantity: 1
      };

      // Limpiar texto de precio "BS. 77" -> 77
      function parsePrice(priceStr: string): number {
        // Eliminar primero la palabra "BS." o "Bs." para evitar que el punto de la abreviación se tome como decimal (.81)
        const cleanStr = priceStr.replace(/BS\./i, '').replace(/Bs\./i, '').replace(/BS/i, '').replace(/Bs/i, '');
        return parseFloat(cleanStr.replace(/[^\d.]/g, '')) || 0;
      }

      // Guardar y Actualizar
      function saveCart() {
        localStorage.setItem('taboada_cart', JSON.stringify(cart));
        updateCartUI();
      }

      function updateCartUI() {
        const totalItems = cart.reduce((acc: number, item: any) => acc + item.quantity, 0);
        if (cartCountBadge) {
          cartCountBadge.textContent = totalItems.toString();
        }

        // Renderizar items del drawer
        if (cartItemsList) {
          const itemsElements = cartItemsList.querySelectorAll('.cart-item-row');
          itemsElements.forEach(el => el.remove());

          if (cart.length === 0) {
            cartEmptyMsg?.classList.remove('hidden');
            if (cartTotalPrice) cartTotalPrice.textContent = "BS. 0";
          } else {
            cartEmptyMsg?.classList.add('hidden');
            let grandTotal = 0;

            cart.forEach((item: any, index: number) => {
              const itemTotal = item.price * item.quantity;
              grandTotal += itemTotal;

              const itemRow = document.createElement('div');
              itemRow.className = 'cart-item-row flex items-center justify-between gap-3 p-3 bg-white/5 rounded-2xl border border-white/5';
              itemRow.innerHTML = `
                <div class="flex items-center gap-3 flex-grow">
                  <img src="${item.img}" alt="${item.name}" class="w-12 h-12 object-contain bg-white/5 rounded-lg p-1" />
                  <div class="text-left">
                    <span class="block text-xs font-bold text-white line-clamp-1">${item.name}</span>
                    <span class="block text-[9px] text-[#f6d98d] font-bold">${item.size}</span>
                    <span class="block text-[10px] text-white/60 mt-0.5">BS. ${item.price} c/u</span>
                  </div>
                </div>
                <div class="flex flex-col items-end justify-between gap-1 flex-shrink-0">
                  <button class="cart-remove-item text-white/40 hover:text-red-400 text-xs font-bold p-1 cursor-pointer transition-colors" data-index="${index}">✕</button>
                  <div class="flex items-center gap-2 mt-1">
                    <button class="cart-qty-dec w-6 h-6 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center text-xs font-bold cursor-pointer" data-index="${index}">-</button>
                    <span class="text-xs font-black text-white w-4 text-center">${item.quantity}</span>
                    <button class="cart-qty-inc w-6 h-6 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center text-xs font-bold cursor-pointer" data-index="${index}">+</button>
                  </div>
                </div>
              `;
              cartItemsList.appendChild(itemRow);
            });

            if (cartTotalPrice) {
              cartTotalPrice.textContent = `BS. ${grandTotal.toFixed(1)}`;
            }
          }
        }

        bindCartDrawerEvents();
      }

      function bindCartDrawerEvents() {
        const removeButtons = document.querySelectorAll('.cart-remove-item');
        removeButtons.forEach(btn => {
          btn.addEventListener('click', (e) => {
            const idx = parseInt((e.currentTarget as HTMLButtonElement).getAttribute('data-index') || '0', 10);
            cart.splice(idx, 1);
            saveCart();
          });
        });

        const decButtons = document.querySelectorAll('.cart-qty-dec');
        decButtons.forEach(btn => {
          btn.addEventListener('click', (e) => {
            const idx = parseInt((e.currentTarget as HTMLButtonElement).getAttribute('data-index') || '0', 10);
            if (cart[idx].quantity > 1) {
              cart[idx].quantity -= 1;
            } else {
              cart.splice(idx, 1);
            }
            saveCart();
          });
        });

        const incButtons = document.querySelectorAll('.cart-qty-inc');
        incButtons.forEach(btn => {
          btn.addEventListener('click', (e) => {
            const idx = parseInt((e.currentTarget as HTMLButtonElement).getAttribute('data-index') || '0', 10);
            cart[idx].quantity += 1;
            saveCart();
          });
        });
      }

      function openCartDrawer() {
        cartDrawer?.classList.remove('translate-x-full');
        cartOverlay?.classList.remove('hidden');
      }

      function closeCartDrawer() {
        cartDrawer?.classList.add('translate-x-full');
        cartOverlay?.classList.add('hidden');
      }

      function openQtyModal(name: string, size: string, img: string, price: number) {
        modalActiveProduct = { name, size, img, price, quantity: 1 };
        
        if (modalProdName) modalProdName.textContent = name;
        if (modalProdSize) modalProdSize.textContent = size;
        if (modalProdImg) modalProdImg.src = img;
        if (modalQtyVal) modalQtyVal.textContent = "1";
        
        qtyModalOverlay?.classList.remove('hidden');
        qtyModal?.classList.remove('hidden');
        
        setTimeout(() => {
          qtyModal?.classList.remove('scale-95', 'opacity-0');
          qtyModal?.classList.add('scale-100', 'opacity-100');
        }, 10);
      }

      function closeQtyModal() {
        qtyModal?.classList.remove('scale-100', 'opacity-100');
        qtyModal?.classList.add('scale-95', 'opacity-0');
        
        setTimeout(() => {
          qtyModal?.classList.add('hidden');
          qtyModalOverlay?.classList.add('hidden');
        }, 300);
      }


      // Enlaces de eventos principales
      const buyButtons = document.querySelectorAll('.add-to-cart-btn');
      buyButtons.forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          const name = target.getAttribute('data-name') || 'Chocolate Taboada';
          const size = target.getAttribute('data-size') || 'Edición Especial';
          const img = target.getAttribute('data-img') || '/img/produc1.png';
          
          const priceKey = currentCity === 'cochabamba' ? 'data-price-cochabamba' : 'data-price-lapaz';
          const priceStr = target.getAttribute(priceKey) || target.getAttribute('data-price-cochabamba') || '75';
          const price = parsePrice(priceStr);

          if (typeof (window as any).addToCart === 'function') {
            (window as any).addToCart({
              id: name.toLowerCase().replace(/\s+/g, '-'),
              name: name,
              size: size,
              img: img,
              price: price
            });
          }
        });
      });

      // Compra directa de un solo producto
      const directBuyButtons = document.querySelectorAll('.direct-buy-btn');
      directBuyButtons.forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          const name = target.getAttribute('data-name') || '';
          const size = target.getAttribute('data-size') || '';
          
          const priceKey = currentCity === 'cochabamba' ? 'data-price-cochabamba' : 'data-price-lapaz';
          const priceStr = target.getAttribute(priceKey) || target.getAttribute('data-price-cochabamba') || '';
          const priceVal = parsePrice(priceStr);
          
          const cityLabel = currentCity === 'cochabamba' ? 'Cochabamba' : 'La Paz';
          
          let message = `¡Hola! Quisiera comprar el siguiente producto de Chocolates Taboada:\n\n`;
          message += `Ciudad de entrega: ${cityLabel}\n`;
          message += `------------------------------------------\n`;
          message += `• 1 x ${name} (${size})\n`;
          message += `  Precio unitario: BS. ${priceVal.toFixed(1)}\n`;
          message += `  Subtotal: BS. ${priceVal.toFixed(1)}\n`;
          message += `------------------------------------------\n`;
          message += `Total a pagar: BS. ${priceVal.toFixed(1)}\n\n`;
          message += `¡Muchas gracias!`;
          
          const waNumber = "59179786916";
          const encodedMsg = encodeURIComponent(message);
          const waLink = `https://wa.me/${waNumber}?text=${encodedMsg}`;
          
          window.open(waLink, '_blank');
        });
      });

      modalQtyMinus?.addEventListener('click', () => {
        if (modalActiveProduct.quantity > 1) {
          modalActiveProduct.quantity -= 1;
          if (modalQtyVal) modalQtyVal.textContent = modalActiveProduct.quantity.toString();
        }
      });

      modalQtyPlus?.addEventListener('click', () => {
        modalActiveProduct.quantity += 1;
        if (modalQtyVal) modalQtyVal.textContent = modalActiveProduct.quantity.toString();
      });

      modalAddBtn?.addEventListener('click', () => {
        const existingIdx = cart.findIndex((item: any) => item.name === modalActiveProduct.name && item.size === modalActiveProduct.size);
        if (existingIdx > -1) {
          cart[existingIdx].quantity += modalActiveProduct.quantity;
        } else {
          cart.push({
            name: modalActiveProduct.name,
            size: modalActiveProduct.size,
            img: modalActiveProduct.img,
            price: modalActiveProduct.price,
            quantity: modalActiveProduct.quantity
          });
        }
        
        saveCart();
        closeQtyModal();
        
        setTimeout(() => {
          openCartDrawer();
        }, 400);
      });

      floatingCartBtn?.addEventListener('click', () => {
        if (typeof (window as any).openCartDrawer === 'function') {
          (window as any).openCartDrawer();
        }
      });
      cartDrawerClose?.addEventListener('click', closeCartDrawer);
      cartOverlay?.addEventListener('click', closeCartDrawer);

      cartCheckoutBtn?.addEventListener('click', () => {
        if (cart.length === 0) return;

        const cityLabel = currentCity === 'cochabamba' ? 'Cochabamba' : 'La Paz';
        let message = `¡Hola! Quisiera realizar el siguiente pedido de Chocolates Taboada:\n\n`;
        message += `Ciudad de entrega: ${cityLabel}\n`;
        message += `------------------------------------------\n`;
        
        let total = 0;
        cart.forEach((item: any) => {
          const itemTotal = item.price * item.quantity;
          total += itemTotal;
          message += `• ${item.quantity} x ${item.name} (${item.size})\n`;
          message += `  Precio unitario: BS. ${item.price.toFixed(1)}\n`;
          message += `  Subtotal: BS. ${itemTotal.toFixed(1)}\n\n`;
        });

        message += `------------------------------------------\n`;
        message += `Total a pagar: BS. ${total.toFixed(1)}\n\n`;
        message += `¡Muchas gracias!`;
        
        const waNumber = "59179786916";
        const encodedMsg = encodeURIComponent(message);
        const waLink = `https://wa.me/${waNumber}?text=${encodedMsg}`;
        
        cart = [];
        saveCart();
        closeCartDrawer();

        window.open(waLink, '_blank');
      });

      updateCartUI();

      // ── CAMBIO DE COLOR DEL NAVBAR AL HACER SCROLL ──
      const navbar = document.getElementById('main-navbar');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          navbar?.classList.add('bg-[#2A1612]/95', 'backdrop-blur-[14px]', 'border-b', 'border-white/10', 'shadow-lg');
          navbar?.classList.remove('bg-transparent', 'border-transparent', 'hover:bg-white/10');
        } else {
          navbar?.classList.remove('bg-[#2A1612]/95', 'backdrop-blur-[14px]', 'border-b', 'border-white/10', 'shadow-lg');
          navbar?.classList.add('bg-transparent', 'border-transparent', 'hover:bg-white/10');
        }
      });
    });
  </script>

  <style>
    @import url("https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;1,400&family=Pinyon+Script&display=swap");

    .font-elegante {
      font-family: "Playfair Display", serif;
    }

    .font-cursiva {
      font-family: "Pinyon Script", cursive;
    }
  </style>

  

  <!-- ======================================================== -->
  <!-- COMPONENTES DEL CARRITO DE COMPRA E INTERACTIVOS -->
  <!-- ======================================================== -->

  <!-- BOTÓN FLOTANTE DEL CARRITO -->
  <button
    id="floating-cart-btn"
    class="fixed bottom-6 right-6 z-[990] w-14 h-14 rounded-full bg-[#dcb041] hover:bg-[#FAF5F0] border border-[#dcb041] text-[#2A1612] flex items-center justify-center shadow-[0_4px_25px_rgba(220,176,65,0.45)] hover:scale-105 active:scale-95 transition-all duration-300 cursor-pointer"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
    </svg>
    <span
      id="cart-count-badge"
      class="absolute -top-1 -right-1 bg-[#e53e3e] text-white text-[10px] font-extrabold w-5 h-5 rounded-full flex items-center justify-center border border-white"
    >
      0
    </span>
  </button>

  <!-- OVERLAY Y MODAL DE SELECCIÓN DE CANTIDAD (POP-UP) -->
  <div
    id="quantity-modal-overlay"
    class="fixed inset-0 bg-black/70 z-[1100] hidden backdrop-blur-[2px] transition-all duration-300"
  ></div>
  <div
    id="quantity-modal"
    class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] max-w-md bg-[#FAF5F0] border border-[#e8dccb] rounded-[2.5rem] shadow-2xl p-8 z-[1101] hidden flex flex-col items-center justify-between transition-all duration-300 scale-95 opacity-0"
  >
    <!-- Botón de Cerrar Modal -->
    <button
      id="quantity-modal-close"
      class="absolute top-4 right-4 w-8 h-8 rounded-full flex items-center justify-center bg-gray-200/50 hover:bg-gray-200 text-gray-700 transition-colors duration-200 cursor-pointer font-bold"
    >
      ✕
    </button>

    <div class="w-full text-center">
      <h3 id="modal-product-name" class="text-xl font-bold font-serif text-[#2A1612] leading-tight"></h3>
      <span id="modal-product-size" class="block text-xs text-[#8f6c49] font-sans mt-0.5 font-bold"></span>
      
      <div class="w-full flex justify-center my-6">
        <img 
          id="modal-product-img" 
          src="" 
          alt="Producto" 
          class="w-40 h-40 object-contain drop-shadow-xl"
        />
      </div>

      <!-- Selector de cantidad -->
      <div class="flex items-center justify-center gap-6 mt-4">
        <button
          id="modal-qty-minus"
          class="w-10 h-10 rounded-full border border-[#2A1612]/30 flex items-center justify-center font-bold text-lg text-[#2A1612] bg-white/60 hover:bg-white active:scale-95 transition-all cursor-pointer"
        >
          -
        </button>
        <span id="modal-qty-val" class="w-12 text-center text-xl font-black text-[#2A1612]">1</span>
        <button
          id="modal-qty-plus"
          class="w-10 h-10 rounded-full border border-[#2A1612]/30 flex items-center justify-center font-bold text-lg text-[#2A1612] bg-white/60 hover:bg-white active:scale-95 transition-all cursor-pointer"
        >
          +
        </button>
      </div>


      <!-- Botón de agregar -->
      <button
        id="modal-add-btn"
        class="w-full mt-6 py-4 rounded-full bg-[#dcb041] hover:bg-[#2A1612] hover:text-[#dcb041] text-[#2A1612] font-black text-sm shadow-md hover:shadow-lg transition-all duration-300 cursor-pointer"
      >
        Agregar al Carrito
      </button>
    </div>
  </div>

  <!-- OVERLAY Y DRAWER DE CARRITO (SIDEBAR) -->
  <div
    id="cart-overlay"
    class="fixed inset-0 bg-black/60 z-[1000] hidden backdrop-blur-[2px] transition-all duration-300"
  ></div>
  <div
    id="cart-drawer"
    class="fixed top-0 right-0 h-full w-full sm:w-[420px] bg-[#2A1612]/98 border-l border-white/10 shadow-2xl z-[1001] translate-x-full transition-transform duration-500 ease-in-out flex flex-col"
  >
    <!-- Cabecera del Carrito -->
    <div class="p-6 border-b border-white/10 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <svg class="w-6 h-6 text-[#f6d98d]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
        </svg>
        <h3 class="text-xl font-serif text-[#f6d98d] font-bold">Tu Pedido</h3>
      </div>
      <button
        id="cart-drawer-close"
        class="w-8 h-8 rounded-full flex items-center justify-center bg-white/10 hover:bg-white/20 text-white transition-colors duration-200 cursor-pointer font-bold"
      >
        ✕
      </button>
    </div>

    <!-- Lista de Productos en el Carrito (Scrollable) -->
    <div id="cart-items-list" class="flex-grow overflow-y-auto p-6 space-y-4">
      <!-- Los productos se inyectarán dinámicamente aquí -->
      <div id="cart-empty-msg" class="h-full flex flex-col items-center justify-center text-center text-white/50">
        <svg class="w-12 h-12 mb-3 text-white/20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386l.542 7.962A2.25 2.25 0 006.402 13h10.196a2.25 2.25 0 002.21-1.944L18.75 3m-16.5 0h13.5m-16.5 0l.344-1.5H19.5" />
        </svg>
        <p class="text-sm font-bold">Tu carrito está vacío</p>
        <span class="text-xs mt-1">Explora nuestras colecciones y agrega tus chocolates favoritos</span>
      </div>
    </div>

    <!-- Resumen y Checkout del Carrito -->
    <div class="p-6 border-t border-white/10 bg-[#251210]/60">
      <div class="flex items-center justify-between mb-4">
        <span class="text-white/60 text-sm font-semibold">Total estimado:</span>
        <span id="cart-total-price" class="text-2xl font-serif font-black text-[#f6d98d]">BS. 0</span>
      </div>
      
      <button
        id="cart-checkout-btn"
        class="group w-full py-4 rounded-full bg-gradient-to-r from-[#dcb041] to-[#f4c856] text-[#2A1612] font-black text-sm shadow-lg hover:shadow-[0_4px_25px_rgba(220,176,65,0.45)] hover:scale-[1.02] active:scale-95 transition-all duration-300 cursor-pointer flex items-center justify-center gap-2"
      >
