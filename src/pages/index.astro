  <section
    id="cajas-especiales"
    class="relative bg-gradient-to-br from-[#FAF5F0] via-[#F3ECE3] to-[#FAF5F0] py-16 md:py-24 border-t border-[#e8dccb]/50 overflow-hidden"
  >
    <div
      id="cajas-especiales-bg"
      class="absolute inset-0 bg-gradient-to-br from-[#FAF5F0] via-[#F3ECE3] to-[#FAF5F0] transition-all duration-500"
    >
    </div>

    <div
      class="absolute top-0 right-0 w-96 h-96 bg-gradient-radial from-amber-100/20 to-transparent blur-[100px] opacity-60"
    >
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="mb-10 md:mb-16">
        <div class="flex justify-start mb-8 md:mb-10">
          <h2
            class="text-3xl md:text-5xl font-elegante font-bold text-[#2A1612] relative inline-block tracking-tight"
          >
            Colecciones

            <!-- línea elegante -->
            <span
              class="absolute left-0 -bottom-3 w-28 h-[4px] bg-[#dcb041] rounded-full shadow-[0_0_10px_rgba(220,176,65,0.35)]"
            ></span>
          </h2>
        </div>

        <!-- FILTROS DE CATEGORÍAS -->
        <div class="mb-12 overflow-x-auto whitespace-nowrap pb-4 scrollbar-none flex gap-2 md:gap-3 max-w-full">
          {categories.map((cat) => (
            <button
              type="button"
              class={`cat-btn px-5 py-2.5 rounded-full text-xs md:text-sm font-semibold transition-all duration-300 cursor-pointer
                ${cat.id === 'todo' 
                  ? 'bg-[#dcb041] text-[#2e1119] shadow-[0_6px_18px_rgba(220,176,65,0.25)]' 
                  : 'bg-[#fbf8f3] border border-[#e8dccb] text-[#2A1612] hover:bg-[#FAF0E6]'
                }`}
              data-target={cat.id}
            >
              {cat.label}
            </button>
          ))}
        </div>

        <!-- GRID DE PRODUCTOS -->
        <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 lg:gap-8 min-h-[450px]">
          {products.map((product) => (
            <div
              class="product-card group relative bg-[#fbf8f3]/95 rounded-[2rem] p-6 border border-[#e8dccb] flex flex-col overflow-hidden transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_8px_30px_rgb(251,207,232,0.4)]"
              data-categories={product.category}
              data-available={product.available.join(" ")}
              data-price-cochabamba={product.price.cochabamba}
              data-price-lapaz={product.price["la-paz"]}
            >
              <!-- IMAGEN -->
              <div class="w-full h-56 mb-6 flex items-center justify-center relative z-10">
                <img
                  src={product.img}
                  alt={product.name}
                  class="object-contain max-h-full drop-shadow-xl group-hover:scale-110 transition-transform duration-500 relative z-10"
                />
              </div>

              <!-- CONTENIDO -->
              <div class="relative z-10 flex-grow flex flex-col">
                <h3 class="text-xl font-serif text-[#2A1612] font-bold leading-tight mb-1">
                  {product.name} <br />
                  <span class="text-base font-normal">{product.size}</span>
                </h3>
                <p class="text-[11px] text-[#8f6c49]/80 leading-relaxed mb-6 flex-grow font-sans">
                  {product.desc}
                </p>
              </div>

              <!-- PRECIO Y COMPRA -->
              <div class="relative z-10 flex items-end justify-between mt-auto pt-4 border-t border-[#e8dccb]/70">
                <div>
                  <span class="block text-[9px] text-[#8f6c49] uppercase mb-0.5 tracking-wider font-sans">Precio</span>
                  <p class="product-price-label text-xl font-serif font-bold text-[#2A1612]">{product.price.cochabamba}</p>
                </div>

                <a
                  href={product.link}
                  target="_blank"
                  rel="noopener"
                  class="bg-[#f6d98d] hover:bg-[#f0cb69] text-[#3a1823] text-xs font-bold px-5 py-2.5 rounded-full transition-all duration-300 shadow-md text-center"
                >
                  Comprar
                </a>
              </div>
            </div>
          ))}

          <!-- MENSAJE DE RESULTADO VACÍO -->
          <div id="no-products-msg" class="hidden col-span-full py-20 text-center">
            <p class="text-[#8f6c49] text-lg font-medium font-sans">No hay productos en esta categoría por el momento.</p>
          </div>
        </div>

        <!-- BOTÓN VER MÁS / VER MENOS -->
        <div id="see-more-container" class="flex justify-end mt-12 hidden">
          <button
            id="see-more-btn"
            type="button"
            class="px-8 py-3.5 rounded-full border border-[#2A1612] text-[#2A1612] font-semibold text-sm hover:bg-[#2A1612] hover:text-white transition-all duration-300 shadow-md cursor-pointer font-sans"
          >
            Ver más
          </button>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Selectores de Categorías
      const catButtons = document.querySelectorAll('.cat-btn');
      const cards = document.querySelectorAll('.product-card');
      const noProductsMsg = document.getElementById('no-products-msg');

      // Selectores de Ubicación
      const citySelectorBtn = document.getElementById('city-selector-btn');
      const cityDropdown = document.getElementById('city-dropdown');
      const activeCityName = document.getElementById('active-city-name');
      const cityOptButtons = document.querySelectorAll('.city-opt-btn');
      const bgOverlay = document.getElementById('cajas-especiales-bg');
      const heroBgCover = document.getElementById('hero-bg-cover');

      // Selectores de Ver Más
      const seeMoreContainer = document.getElementById('see-more-container');
      const seeMoreBtn = document.getElementById('see-more-btn');

      // Estados actuales
      let currentCategory = 'todo';
      let currentCity = 'cochabamba'; // Valor inicial / fallback
      let isExpanded = false; // Estado del botón Ver Más

      // ── DROPDOWN SELECTOR DE UBICACIÓN ──
      citySelectorBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        cityDropdown?.classList.toggle('hidden');
      });

      document.addEventListener('click', () => {
        cityDropdown?.classList.add('hidden');
      });

      // ── ACTUALIZAR CIUDAD SELECCIONADA ──
      function updateCity(city: string) {
        currentCity = city;
        localStorage.setItem('selected_city', city);

        // Actualizar etiqueta del botón
        if (activeCityName) {
          activeCityName.textContent = city === 'cochabamba' ? 'Cochabamba' : 'La Paz';
        }

        // La portada del Hero se mantiene estática con la imagen por defecto original

        // Actualizar el degradado de fondo de Colecciones
        if (bgOverlay) {
          // Remover clases viejas de gradientes
          bgOverlay.classList.remove(
            'from-[#FAF5F0]', 'via-[#F3ECE3]', 'to-[#FAF5F0]',
            'from-[#FAF6F2]', 'via-[#EADCD0]', 'to-[#FAF6F2]',
            'from-[#FAF7F5]', 'via-[#E2DFD8]', 'to-[#FAF7F5]'
          );
          
          // Añadir clases nuevas basadas en la ciudad
          if (city === 'cochabamba') {
            bgOverlay.classList.add('from-[#FAF6F2]', 'via-[#EADCD0]', 'to-[#FAF6F2]');
          } else if (city === 'la-paz') {
            bgOverlay.classList.add('from-[#FAF7F5]', 'via-[#E2DFD8]', 'to-[#FAF7F5]');
          }
        }

        // Refrescar el filtrado de productos y los precios
        filterProducts();
      }

      // ── FILTRAR PRODUCTOS Y PRECIOS ──
      function filterProducts() {
        let matchingCards: Element[] = [];

        // 1. Clasificar tarjetas que coinciden con los filtros activos
        cards.forEach((card) => {
          const categoriesAttr = card.getAttribute('data-categories') || '';
          const categoriesList = categoriesAttr.split(' ');
          const availableAttr = card.getAttribute('data-available') || '';
          const availableList = availableAttr.split(' ');

          const matchesCategory = currentCategory === 'todo' || categoriesList.includes(currentCategory);
          const matchesCity = availableList.includes(currentCity);

          // Actualizar el precio dinámicamente antes de mostrar/ocultar
          const priceLabel = card.querySelector('.product-price-label');
          if (priceLabel) {
            const priceKey = currentCity === 'cochabamba' ? 'data-price-cochabamba' : 'data-price-lapaz';
            priceLabel.textContent = card.getAttribute(priceKey) || '';
          }

          if (matchesCategory && matchesCity) {
            matchingCards.push(card);
          } else {
            card.classList.add('hidden');
          }
        });

        // 2. Gestionar la visualización del botón "Ver más"
        const limit = 4;
        if (matchingCards.length > limit) {
          seeMoreContainer?.classList.remove('hidden');
          if (seeMoreBtn) {
            seeMoreBtn.textContent = isExpanded ? 'Ver menos' : 'Ver más';
          }

          matchingCards.forEach((card, index) => {
            if (isExpanded || index < limit) {
              card.classList.remove('hidden');
              // Pequeña animación de entrada
              (card as HTMLElement).style.opacity = '0';
              setTimeout(() => {
                (card as HTMLElement).style.opacity = '1';
                (card as HTMLElement).style.transition = 'opacity 0.4s ease, transform 0.4s ease';
              }, 30);
            } else {
              card.classList.add('hidden');
            }
          });
        } else {
          // Ocultar botón si hay 4 o menos productos y mostrarlos todos
          seeMoreContainer?.classList.add('hidden');
          matchingCards.forEach((card) => {
            card.classList.remove('hidden');
            (card as HTMLElement).style.opacity = '0';
            setTimeout(() => {
              (card as HTMLElement).style.opacity = '1';
              (card as HTMLElement).style.transition = 'opacity 0.4s ease, transform 0.4s ease';
            }, 30);
          });
        }

        // Mostrar u ocultar mensaje vacío
        if (matchingCards.length === 0) {
          noProductsMsg?.classList.remove('hidden');
        } else {
          noProductsMsg?.classList.add('hidden');
        }
      }

      // Clic en Ver Más / Ver Menos
      seeMoreBtn?.addEventListener('click', () => {
        isExpanded = !isExpanded;
        filterProducts();
      });

      // Clics en opciones de ciudades
      cityOptButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const selected = btn.getAttribute('data-city') || 'cochabamba';
          isExpanded = false; // Resetear expansión
          updateCity(selected);
        });
      });

      // Clics en botones de categorías
      catButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          currentCategory = btn.getAttribute('data-target') || 'todo';
          isExpanded = false; // Resetear expansión

          // Actualizar estilos de los botones de categoría
          catButtons.forEach((b) => {
            b.classList.remove('bg-[#dcb041]', 'text-[#2e1119]', 'shadow-[0_6px_18px_rgba(220,176,65,0.25)]');
            b.classList.add('bg-[#fbf8f3]', 'border', 'border-[#e8dccb]', 'text-[#2A1612]', 'hover:bg-[#FAF0E6]');
          });

          btn.classList.add('bg-[#dcb041]', 'text-[#2e1119]', 'shadow-[0_6px_18px_rgba(220,176,65,0.25)]');
          btn.classList.remove('bg-[#fbf8f3]', 'border', 'border-[#e8dccb]', 'text-[#2A1612]', 'hover:bg-[#FAF0E6]');

          filterProducts();
        });
      });

      // ── INICIALIZACIÓN Y DETECCIÓN DE UBICACIÓN ──
      const savedCity = localStorage.getItem('selected_city');
      if (savedCity && (savedCity === 'cochabamba' || savedCity === 'la-paz')) {
        updateCity(savedCity);
      } else {
        // Intentar primero con la geolocalización nativa del navegador (GPS/WiFi)
        if (navigator.geolocation) {
          navigator.geolocation.getCurrentPosition(
            (position) => {
              const lat = position.coords.latitude;
              const lon = position.coords.longitude;
              
              // Coordenadas de referencia en Bolivia
              const latCocha = -17.3895;
              const lonCocha = -66.1568;
              const latLaPaz = -16.5000;
              const lonLaPaz = -68.1100;
              
              // Distancia euclidiana aproximada para determinar el más cercano
              const distCocha = Math.pow(lat - latCocha, 2) + Math.pow(lon - lonCocha, 2);
              const distLaPaz = Math.pow(lat - latLaPaz, 2) + Math.pow(lon - lonLaPaz, 2);
              
              const detected = distCocha < distLaPaz ? 'cochabamba' : 'la-paz';
              console.log("Geolocalización nativa (GPS/WiFi) exitosa. Coordenadas:", lat, lon, "-> Asignado a:", detected);
              updateCity(detected);
            },
            (error) => {
              console.warn("Geolocalización nativa rechazada o falló. Usando IP como fallback. Código:", error.code);
              fallbackIPDetection();
            },
            { timeout: 5000 }
          );
        } else {
          fallbackIPDetection();
        }
      }

      function fallbackIPDetection() {
        // Ejecutar detección por IP de freeipapi.com
        fetch('https://freeipapi.com/api/json')
          .then((res) => {
            if (res.ok) return res.json();
            throw new Error('API Error');
          })
          .then((data) => {
            const cityName = (data.cityName || '').toLowerCase();
            const detected = cityName.includes('paz') ? 'la-paz' : 'cochabamba';
            console.log("--- Chocolates Taboada (Diagnóstico Fallback IP) ---");
            console.log("Ciudad de IP detectada:", data.cityName || "No provista");
            console.log("Región/País de IP:", data.regionName, "/", data.countryName);
            console.log("Ciudad asignada en la Web:", detected === 'la-paz' ? "La Paz" : "Cochabamba");
            console.log("-----------------------------------------");
            updateCity(detected);
          })
          .catch((err) => {
            console.error('No se pudo determinar la ubicación IP, usando Cochabamba por defecto:', err);
            updateCity('cochabamba'); // Fallback por defecto
          });
      }
    });
  </script>

