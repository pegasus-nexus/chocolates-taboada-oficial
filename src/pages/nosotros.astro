  <!-- SCRIPTS -->
  <script>
    // ── MENÚ MÓVIL (DRAWER) ──
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileCloseBtn = document.getElementById("mobile-close-btn");
    const mobileDrawer = document.getElementById("mobile-drawer");
    const drawerOverlay = document.getElementById("drawer-overlay");
    const mobileLinks = document.querySelectorAll(".mobile-link");

    function openDrawer() {
      mobileDrawer?.classList.remove("translate-x-full");
      drawerOverlay?.classList.remove("opacity-0", "pointer-events-none");
    }

    function closeDrawer() {
      mobileDrawer?.classList.add("translate-x-full");
      drawerOverlay?.classList.add("opacity-0", "pointer-events-none");
    }

    mobileMenuBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      openDrawer();
    });

    mobileCloseBtn?.addEventListener("click", closeDrawer);
    drawerOverlay?.addEventListener("click", closeDrawer);

    mobileLinks.forEach((link) => {
      link.addEventListener("click", closeDrawer);
    });

    // ── CARRUSEL Y LÍNEA DE TIEMPO HORIZONTAL INTERACTIVA ──
    const nodes = document.querySelectorAll(".timeline-node-btn");
    const slides = document.querySelectorAll(".timeline-slide");
    const prevBtn = document.getElementById("prev-slide-btn");
    const nextBtn = document.getElementById("next-slide-btn");
    const progressLine = document.getElementById("timeline-progress-line");

    let currentIndex = 0;
    const totalSlides = slides.length;

    function updateCarousel(index: number) {
      currentIndex = index;

      // 1. Actualizar el estado visual de los nodos numerados
      nodes.forEach((node, i) => {
        const circle = node.querySelector("div");
        const text = node.querySelector("span");

        if (i === currentIndex) {
          circle?.classList.remove(
            "bg-gray-300",
            "text-gray-500",
            "border-[#e8dccb]",
          );
          circle?.classList.add(
            "bg-[#2A1612]",
            "text-[#dcb041]",
            "border-[#2A1612]",
            "scale-115",
          );
          text?.classList.remove("text-gray-400");
          text?.classList.add("text-[#8f6c49]", "font-extrabold");
        } else {
          circle?.classList.add(
            "bg-gray-300",
            "text-gray-500",
            "border-[#e8dccb]",
          );
          circle?.classList.remove(
            "bg-[#2A1612]",
            "text-[#dcb041]",
            "border-[#2A1612]",
            "scale-115",
          );
          text?.classList.add("text-gray-400");
          text?.classList.remove("text-[#8f6c49]", "font-extrabold");
        }
      });

      // 3. Mostrar/ocultar las diapositivas del carrusel con transiciones
      slides.forEach((slide, i) => {
        const slideEl = slide as HTMLElement;
        if (i === currentIndex) {
          slideEl.classList.remove(
            "opacity-0",
            "pointer-events-none",
            "translate-x-12",
          );
          slideEl.classList.add("opacity-100", "relative", "translate-x-0");
        } else {
          slideEl.classList.add("opacity-0", "pointer-events-none");
          slideEl.classList.remove("opacity-100", "relative", "translate-x-0");

          if (i > currentIndex) {
            slideEl.classList.add("translate-x-12");
          } else {
            slideEl.classList.remove("translate-x-12");
          }
        }
      });
    }

    nodes.forEach((node) => {
      node.addEventListener("click", (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const index = parseInt(btn.getAttribute("data-index") || "0", 10);
        updateCarousel(index);
      });
    });

    prevBtn?.addEventListener("click", () => {
      let index = currentIndex - 1;
      if (index < 0) index = totalSlides - 1;
      updateCarousel(index);
    });

    nextBtn?.addEventListener("click", () => {
      let index = currentIndex + 1;
      if (index >= totalSlides) index = 0;
      updateCarousel(index);
    });

    // ── CAMBIO DE COLOR DEL NAVBAR AL HACER SCROLL ──
    const navbar = document.getElementById("main-navbar");
    window.addEventListener("scroll", () => {
      if (window.scrollY > 50) {
        navbar?.classList.add(
          "bg-[#2A1612]/95",
          "backdrop-blur-[14px]",
          "border-b",
          "border-white/10",
          "shadow-lg",
        );
        navbar?.classList.remove("bg-transparent", "border-transparent");
      } else {
        navbar?.classList.remove(
          "bg-[#2A1612]/95",
          "backdrop-blur-[14px]",
          "border-b",
          "border-white/10",
          "shadow-lg",
        );
        navbar?.classList.add("bg-transparent", "border-transparent");
      }
    });

    // Inicializar carrusel
    updateCarousel(0);
  </script>
