---
import AppLayout from '../layouts/AppLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// 1. Datos de los beneficios con VALIDEZ PERSONALIZADA e imágenes corregidas
const rewards = [
  { id:'trufa', title:'Chocolate Amargo', tag:'Regalo VIP', desc:'Pieza maestra de cacao belga.', img:'/img/razon2.png', validity: '2 Semanas' },
  { id:'choco', title:'Trufas de Chocolate', tag:'Exclusivo', desc:'70% cacao amazónico.', img:'/img/especial1.png', validity: '2 Semanas' },
  { id:'cupon2', title:'Gesto 2%', tag:'Cortesía', desc:'Descuento especial de bienvenida.', img:'/img/taboada-logo.png', validity: 'Un mes' },
  { id:'choco3', title:'Gesto 3%', tag:'Exclusivo', desc:'70% cacao amazónico en tu compra.', img:'/img/taboada-logo.png', validity: '2 Semanas' },
  { id:'cupon4', title:'Gesto 4%', tag:'Cortesía', desc:'Descuento especial por compras.', img:'/img/taboada-logo.png', validity: '1 Semana' },
];

// Fecha actual formateada elegante
const rawFecha = new Date().toLocaleDateString('es-ES', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
const fechaHoyFormatted = rawFecha.charAt(0).toUpperCase() + rawFecha.slice(1);
---

<AppLayout title="Comunidad Taboada · Beneficios Exclusivos">

<style is:global>
  :root {
    --oro-viejo: #8f6c49;
    --beige-seda: #FAF5F0;
    --cafe-profundo: #2A1612;
    --font-serif: "Playfair Display", serif; 
  }

  body { background-color: var(--cafe-profundo); color: var(--beige-seda); margin: 0; }

  /* ── SECCIÓN DE BIENVENIDA (Fondo Café Profundo) ── */
  .welcome-container {
    position: relative;
    min-height: 100vh;
    padding: 130px 5% 80px;
    display: flex;
    flex-direction: column;
    background-color: var(--cafe-profundo);
  }

  /* ── BARRA SUPERIOR CON BOTÓN DE REGRESO Y FECHA ── */
  .top-nav-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto 30px;
    width: 100%;
    position: relative;
    z-index: 10;
  }

  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    color: var(--beige-seda);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    border: none;
    padding: 0;
    transition: color 0.3s ease;
  }

  .btn-back:hover {
    color: #dcb041;
  }

  .current-date-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 1.15rem;
    color: #dcb041;
    font-weight: 600;
    font-style: italic;
    font-family: var(--font-serif);
    background: transparent;
    border: none;
    padding: 0;
  }

  .welcome-section {
    text-align: left;
    max-width: 1200px;
    margin: 0 auto 40px;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  /* ── SECCIÓN DE TICKETS COLOR BEIGE (Fondo Claro / Texto Oscuro) ── */
  .ticket-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 20px auto 40px;
    width: 100%;
    position: relative;
    z-index: 10;
  }

  .ticket-wrapper {
    position: relative;
    filter: drop-shadow(0 15px 30px rgba(0, 0, 0, 0.35));
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    height: fit-content;
    overflow: visible !important;
  }
  .ticket-wrapper:hover { transform: translateY(-4px) scale(1.01); }

  .ticket {
    background: transparent;
    display: flex;
    flex-direction: row; 
    border-radius: 24px;
    overflow: visible !important;
    position: relative;
    border: none;
  }

  .ticket-main, .ticket-stub, .ticket-divider { transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.5s ease; }
  .ticket-main { 
    flex: 1; 
    padding: 28px; 
    display: flex; 
    align-items: center; 
    gap: 20px;
    background: linear-gradient(135deg, #FAF5F0 0%, #F3ECE3 100%);
    border-radius: 24px 0 0 24px;
  }
  
  .ticket-img { 
    width: 85px; 
    height: 85px; 
    background: rgba(42, 22, 18, 0.05); 
    border-radius: 20px; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    flex-shrink: 0; 
    border: none; 
  }
  .ticket-img img { max-width: 80%; max-height: 80%; object-fit: contain; filter: drop-shadow(0 5px 15px rgba(0,0,0,0.15)); }

  .ticket-info { 
    text-align: left; 
    position: relative;
    z-index: 10;
  }
  .ticket-tag { font-size: 9px; font-weight: 800; color: #8f6c49; letter-spacing: 0.15em; text-transform: uppercase; }
  .ticket-title { font-family: var(--font-serif); font-size: 1.5rem; color: #2A1612; margin: 4px 0; font-weight: bold; }
  .ticket-desc { font-size: 11px; color: #5D4037; opacity: 0.9; margin-bottom: 8px; line-height: 1.4; font-family: sans-serif; }
  .ticket-loc { font-size: 8px; font-weight: 700; color: #8f6c49; opacity: 0.75; letter-spacing: 0.05em; }

  .ticket-divider { position: relative; display: flex; align-items: center; justify-content: center; width: 2px; }
  .dash-line { width: 2px; height: 100%; border-left: 2px dashed rgba(42, 22, 18, 0.2); }
  .hole { position: absolute; width: 28px; height: 28px; background-color: var(--cafe-profundo); border-radius: 50%; z-index: 5; }
  .hole-start { top: -14px; left: -13px; }
  .hole-end { bottom: -14px; left: -13px; }

  .ticket-stub { 
    width: 130px; 
    background: #F3ECE3;
    background: linear-gradient(135deg, #F3ECE3 0%, #EFE5D8 100%);
    border-radius: 0 24px 24px 0;
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    justify-content: center; 
    padding: 20px 15px; 
    text-align: center; 
    border-left: none; 
  }
  .stub-barcode { font-family: monospace; font-size: 18px; font-weight: 500; color: #2A1612; opacity: 0.45; letter-spacing: 1px; margin-bottom: 8px; }
  .stub-label { font-size: 8px; font-weight: 700; color: #8f6c49; margin-bottom: 12px; letter-spacing: 0.05em; }

  .btn-redeem { background: var(--cafe-profundo); color: var(--beige-seda); border: none; padding: 10px 15px; border-radius: 9999px; font-size: 10px; font-weight: 800; cursor: pointer; transition: all 0.3s ease; letter-spacing: 0.08em; width: 100%; box-shadow: 0 4px 10px rgba(42, 22, 18, 0.2); }
  .btn-redeem:hover { background: #8f6c49; color: #ffffff; transform: translateY(-1px); }
  .btn-redeem:active { transform: scale(0.97); }

  .stamp-redeemed {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(4) rotate(-25deg);
    font-family: var(--font-serif); font-size: 2.2rem; color: #3a1823; border: 3px solid #3a1823;
    padding: 8px 20px; border-radius: 12px; font-weight: 900; opacity: 0; z-index: 100; transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    background: #FAF5F0; pointer-events: none; box-shadow: 0 10px 25px rgba(0,0,0,0.3);
  }

  /* ── STAGE PORTAL CINEMATOGRÁFICO TEMPORAL DE CANJE ── */
  #redeem-portal-stage {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    overflow: visible !important;
  }
  #redeem-portal-stage.active {
    display: flex;
  }

  #redeem-portal-stage .ticket-wrapper {
    position: relative !important;
    transform: scale(1.3) !important;
    width: 100% !important;
    max-width: 520px !important;
    margin: 0 !important;
    filter: drop-shadow(0 35px 80px rgba(0, 0, 0, 0.95)) !important;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    overflow: visible !important;
  }

  @media (max-width: 650px) {
    #redeem-portal-stage .ticket-wrapper {
      transform: scale(1.05) !important;
      max-width: 360px !important;
    }
  }

  #redeem-portal-stage .ticket-wrapper.is-broken .ticket-main { transform: translateX(-45px) rotate(-4deg) !important; }
  #redeem-portal-stage .ticket-wrapper.is-broken .ticket-stub { transform: translate(45px, 25px) rotate(12deg) !important; }
  #redeem-portal-stage .ticket-wrapper.is-broken .ticket-divider { opacity: 0 !important; }
  #redeem-portal-stage .ticket-wrapper.is-stamped .stamp-redeemed { opacity: 1 !important; transform: translate(-50%, -50%) scale(1.2) rotate(-14deg) !important; }

  /* ── ESTADO DE RECOMPENSA PERMANENTE EN LA PÁGINA (TICKET GIGANTE COMPLETO Y MARCA DE AGUA) ── */
  .welcome-container {
    position: relative;
    min-height: 100vh;
    padding: 130px 5% 80px;
    display: flex;
    flex-direction: column;
    background-color: var(--cafe-profundo);
    overflow: visible !important;
  }

  .ticket-container.estado-recompensa-permanente {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    width: 100% !important;
    max-width: 1200px !important;
    margin: 40px auto 40px !important;
    overflow: visible !important;
  }

  .ticket-wrapper.ticket-gigante-final {
    position: relative !important;
    width: 95% !important;
    max-width: 900px !important;
    margin: 0 auto !important;
    filter: drop-shadow(0 35px 70px rgba(0, 0, 0, 0.8)) !important;
    transition: all 0.5s ease;
    overflow: visible !important;
  }

  /* ELIMINAR CUALQUIER LÍMITE O RECORTE DE BORDES */
  .ticket-wrapper.ticket-gigante-final .ticket {
    overflow: visible !important;
    min-height: 240px !important;
    border-radius: 28px !important;
  }

  .ticket-wrapper.ticket-gigante-final .ticket-main {
    padding: 38px 45px !important;
    gap: 30px !important;
  }

  .ticket-wrapper.ticket-gigante-final .ticket-img {
    width: 115px !important;
    height: 115px !important;
    border-radius: 22px !important;
  }

  .ticket-wrapper.ticket-gigante-final .ticket-title {
    font-size: 2.3rem !important;
    margin: 6px 0 8px !important;
  }

  .ticket-wrapper.ticket-gigante-final .ticket-desc {
    font-size: 14.5px !important;
    line-height: 1.6 !important;
    margin-bottom: 12px !important;
  }

  .ticket-wrapper.ticket-gigante-final .ticket-tag {
    font-size: 11px !important;
    letter-spacing: 0.18em !important;
  }

  .ticket-wrapper.ticket-gigante-final .ticket-stub {
    width: 180px !important;
    padding: 25px 20px !important;
  }

  .ticket-wrapper.ticket-gigante-final .stub-barcode {
    font-size: 24px !important;
    margin-bottom: 10px !important;
  }

  .ticket-wrapper.ticket-gigante-final .stub-label {
    font-size: 10px !important;
    margin-bottom: 14px !important;
  }

  /* SELLO MARCA DE AGUA SEMITRANSPARENTE (Z-INDEX 0, OPACIDAD 0.09) */
  .ticket-wrapper.ticket-gigante-final .stamp-redeemed {
    display: block !important;
    font-size: 3.6rem !important;
    border: 5px solid #3a1823 !important;
    color: #3a1823 !important;
    padding: 10px 36px !important;
    border-radius: 16px !important;
    opacity: 0.09 !important;
    z-index: 0 !important;
    transform: translate(-50%, -50%) scale(1) rotate(-14deg) !important;
    background: transparent !important;
    box-shadow: none !important;
    white-space: nowrap !important;
    pointer-events: none !important;
  }

  /* BORDE RASGADO DENTADO COMPLEMENTARIO ESTILO ROMPECABEZAS (100% COHERENTE Y ENCAJABLE) */
  .ticket-wrapper.is-broken .ticket-main {
    transform: translateX(-45px) rotate(-3.5deg) !important;
    clip-path: polygon(
      0 0, 
      100% 0, 
      calc(100% - 8px) 5%, 
      100% 10%, 
      calc(100% - 8px) 15%, 
      100% 20%, 
      calc(100% - 8px) 25%, 
      100% 30%, 
      calc(100% - 8px) 35%, 
      100% 40%, 
      calc(100% - 8px) 45%, 
      100% 50%, 
      calc(100% - 8px) 55%, 
      100% 60%, 
      calc(100% - 8px) 65%, 
      100% 70%, 
      calc(100% - 8px) 75%, 
      100% 80%, 
      calc(100% - 8px) 85%, 
      100% 90%, 
      calc(100% - 8px) 95%, 
      100% 100%, 
      0 100%
    ) !important;
  }

  .ticket-wrapper.is-broken .ticket-stub {
    transform: translate(45px, 22px) rotate(11deg) !important;
    clip-path: polygon(
      0 0, 
      100% 0, 
      100% 100%, 
      0 100%, 
      0 95%, 
      8px 90%, 
      0 85%, 
      8px 80%, 
      0 75%, 
      8px 70%, 
      0 65%, 
      8px 60%, 
      0 55%, 
      8px 50%, 
      0 45%, 
      8px 40%, 
      0 35%, 
      8px 30%, 
      0 25%, 
      8px 20%, 
      0 15%, 
      8px 10%, 
      0 5%
    ) !important;
  }

  .ticket-wrapper.ticket-gigante-final.is-broken .ticket-divider {
    opacity: 0 !important;
  }

  @media (max-width: 900px) {
    .ticket-wrapper.ticket-gigante-final .ticket-main {
      padding: 28px 24px !important;
      gap: 20px !important;
    }
    .ticket-wrapper.ticket-gigante-final .ticket-img {
      width: 90px !important;
      height: 90px !important;
    }
    .ticket-wrapper.ticket-gigante-final .ticket-title {
      font-size: 1.8rem !important;
    }
    .ticket-wrapper.ticket-gigante-final .ticket-stub {
      width: 140px !important;
      padding: 20px 14px !important;
    }
  }

  @media (max-width: 650px) {
    .ticket-wrapper.ticket-gigante-final .ticket {
      flex-direction: column !important;
    }
    .ticket-wrapper.ticket-gigante-final .ticket-stub {
      width: 100% !important;
      border-top: 1px dashed rgba(42,22,18,0.2);
    }
    .ticket-wrapper.ticket-gigante-final.is-broken .ticket-main {
      transform: translateY(-20px) rotate(-2deg) !important;
    }
    .ticket-wrapper.ticket-gigante-final.is-broken .ticket-stub {
      transform: translateY(20px) rotate(4deg) !important;
    }
  }
</style>

<div id="page-root">
  
  <!-- STAGE PORTAL TEMPORAL DE CANJE -->
  <div id="redeem-portal-stage"></div>

  <!-- ── NAVBAR COMPLETO ── -->
  <Navbar />

  <div class="welcome-container">
    
    <!-- Texturas de fondo sutiles -->
    <div class="absolute -right-20 top-1/3 w-96 h-96 bg-gradient-radial from-amber-200/5 to-transparent blur-3xl pointer-events-none"></div>
    <div class="absolute -left-20 top-1/2 w-96 h-96 bg-gradient-radial from-amber-200/5 to-transparent blur-3xl pointer-events-none"></div>

    <!-- BOTÓN DE REGRESO Y FECHA ACTUAL -->
    <div class="top-nav-bar">
      <a href="/" onclick="if(history.length > 1){ history.back(); return false; }" class="btn-back group">
        <svg class="w-5 h-5 text-[#dcb041] group-hover:-translate-x-1.5 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path>
        </svg>
        <span>Regresar</span>
      </a>
      <div class="current-date-badge">
        <svg class="w-5 h-5 md:w-6 md:h-6 text-[#dcb041] flex-shrink-0 not-italic" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zM14.25 12h.008v.008H14.25v-.008zm0 2.25h.008v.008H14.25V15zm0 2.25h.008v.008H14.25v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z"></path>
        </svg>
        <span>{fechaHoyFormatted}</span>
      </div>
    </div>

    <header class="welcome-section">
      <div class="flex items-center gap-2 mb-3">
        <span class="w-6 h-[2px] bg-[#dcb041]"></span>
        <span class="text-xs uppercase tracking-widest text-[#dcb041] font-bold font-sans">Comunidad de Lealtad</span>
      </div>
      
      <h1 id="community-welcome-title" class="font-serif text-4xl md:text-6xl text-[var(--beige-seda)] font-extrabold leading-tight tracking-tight mb-4">
        Comunidad <span class="text-[#dcb041] italic font-semibold">Taboada</span>
      </h1>
      
      <p id="community-welcome-desc" style="font-size: 16px; margin-top: 15px; max-width: 600px; line-height: 1.6; color: #e8dccb; font-family: sans-serif;">
        De cortesía elige tu regalo de bienvenida en grande, el cual podrás canjear exclusivamente en nuestra sucursal de 
        <a href="https://n9.cl/cg9lw" target="_blank" rel="noopener noreferrer" style="color: #f6d98d; text-decoration: underline; font-weight: 700;">
           La Recoleta
        </a>.
      </p>
    </header>

    <section class="ticket-container">
      {rewards.map(r => (
        <div class="ticket-wrapper">
          <div class="ticket" id={r.id}>
            
            <div class="stamp-redeemed">CANJEADO</div>

            <div class="ticket-main">
              <div class="ticket-img">
                <img src={r.img} alt={r.title} />
              </div>
              <div class="ticket-info">
                <span class="ticket-tag">{r.tag}</span>
                <h3 class="ticket-title">{r.title}</h3>
                <p class="ticket-desc">{r.desc}</p>
                <div class="ticket-loc">📍 SOLO VÁLIDO PARA LA SUCURSAL RECOLETA · 2026</div>
              </div>
            </div>

            <div class="ticket-divider">
              <div class="hole hole-start"></div>
              <div class="dash-line"></div>
              <div class="hole hole-end"></div>
            </div>

            <div class="ticket-stub">
              <div class="stub-barcode">|||| || |||</div>
              <span class="stub-label">VALIDEZ: {r.validity}</span>
              <button class="btn-redeem" onclick={`abrirModal('${r.id}')`}>CANJEAR</button>
            </div>

          </div>
        </div>
      ))}
    </section>
  </div>

  <!-- ── FOOTER PRINCIPAL ── -->
  <Footer />

</div>

<script is:inline>
  // ── EFECTOS DE SONIDO PARA LA EXPERIENCIA DE CANJE ──
  const sonidoRasgar = new Audio('/sounds/rasgar.mp3');
  const sonidoSello = new Audio('/sounds/sello.mp3');

  const rewardsData = [
    { id:'trufa', title:'Chocolate Amargo', validity: '2 Semanas' },
    { id:'choco', title:'Trufas de Chocolate', validity: '2 Semanas' },
    { id:'cupon2', title:'Gesto 2%', validity: 'Un mes' },
    { id:'choco3', title:'Gesto 3%', validity: '2 Semanas' },
    { id:'cupon4', title:'Gesto 4%', validity: '1 Semana' }
  ];

  const calculateDeadlineDate = (validityStr, redemptionDateIso) => {
    const startDate = redemptionDateIso ? new Date(redemptionDateIso) : new Date();
    let daysToAdd = 14;
    if (validityStr.includes('1 Semana')) daysToAdd = 7;
    else if (validityStr.includes('2 Semanas')) daysToAdd = 14;
    else if (validityStr.includes('Un mes') || validityStr.includes('1 mes')) daysToAdd = 30;

    const deadline = new Date(startDate.getTime() + daysToAdd * 24 * 60 * 60 * 1000);
    const rawDate = deadline.toLocaleDateString('es-ES', {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    });
    return rawDate.charAt(0).toUpperCase() + rawDate.slice(1);
  };

  window.abrirModal = function(id) {
    if (localStorage.getItem('taboada_redeemed_ticket') || localStorage.getItem('taboada_ticket_reclamado')) {
      alert("Ya has canjeado tu beneficio de bienvenida.");
      return;
    }

    const isRegistered = localStorage.getItem('taboada_user_registered') === 'true';
    if (isRegistered) {
      ejecutarCanjeTicket(id);
    } else {
      if (typeof window.openRegisterModal === 'function') {
        window.openRegisterModal(id);
      }
    }
  };

  window.ejecutarCanjeTicket = function(id) {
    if (localStorage.getItem('taboada_redeemed_ticket') || localStorage.getItem('taboada_ticket_reclamado')) return;

    const ticketElement = document.getElementById(id);
    if (!ticketElement) return;

    const wrapper = ticketElement.closest('.ticket-wrapper');
    const rewardInfo = rewardsData.find(r => r.id === id) || { title: 'Chocolate Amargo', validity: '2 Semanas' };

    // 1. Guardar inmediatamente el canje en localStorage
    const nowIso = new Date().toISOString();
    localStorage.setItem('taboada_redeemed_ticket', id);
    localStorage.setItem('taboada_ticket_reclamado', id);
    localStorage.setItem('taboada_redeemed_title', rewardInfo.title);
    localStorage.setItem('taboada_redeemed_validity', rewardInfo.validity);
    localStorage.setItem('taboada_redeemed_date', nowIso);

    // 2. Mover temporalmente al Stage Portal para la animación cinematográfica
    const portalStage = document.getElementById('redeem-portal-stage');
    if (portalStage && wrapper) {
      portalStage.appendChild(wrapper);
      portalStage.classList.add('active');
    }

    const btn = ticketElement.querySelector('.btn-redeem');
    if (btn) btn.innerText = "VALIDANDO...";

    // 3. Animación de pop + rotura + sello con reproducciones de audio sincronizadas
    setTimeout(() => { wrapper?.classList.add('is-active'); }, 50);

    setTimeout(() => { 
      wrapper?.classList.add('is-broken'); 
      try {
        sonidoRasgar.currentTime = 0;
        sonidoRasgar.play().catch(e => console.log('Audio autoplay notice:', e));
      } catch(e) {}
    }, 700);

    setTimeout(() => { 
      wrapper?.classList.add('is-stamped'); 
      try {
        sonidoSello.currentTime = 0;
        sonidoSello.play().catch(e => console.log('Audio autoplay notice:', e));
      } catch(e) {}
    }, 1400);

    // 4. Tras la animación, cerrar portal y pasar fluidamente al Estado de Recompensa Permanente
    setTimeout(() => {
      if (portalStage) portalStage.classList.remove('active');
      
      const ticketContainer = document.querySelector('.ticket-container');
      if (ticketContainer && wrapper) {
        ticketContainer.appendChild(wrapper);
      }
      
      checkRedeemedState();
    }, 2400);
  };

  const checkRedeemedState = () => {
    const redeemedTicketId = localStorage.getItem('taboada_redeemed_ticket') || localStorage.getItem('taboada_ticket_reclamado');
    const redeemedValidity = localStorage.getItem('taboada_redeemed_validity') || '2 Semanas';
    const redeemedDateIso = localStorage.getItem('taboada_redeemed_date');

    if (!redeemedTicketId) return;

    const ticketElement = document.getElementById(redeemedTicketId);
    if (!ticketElement) return;

    const wrapper = ticketElement.closest('.ticket-wrapper');
    const container = document.querySelector('.ticket-container');
    const descEl = document.getElementById('community-welcome-desc');

    // 1. Reemplazar el texto del subtítulo con íconos SVG vectoriales limpios sin cajas ni bordes
    if (descEl) {
      descEl.innerHTML = `
        <div style="margin-top: 18px; text-align: left;" class="space-y-4">
          <div class="flex items-start gap-3.5">
            <svg class="w-7 h-7 md:w-8 md:h-8 text-[#dcb041] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5m-9-6h.008v.008H12v-.008zM12 15h.008v.008H12V15zm0 2.25h.008v.008H12v-.008zM9.75 15h.008v.008H9.75V15zm0 2.25h.008v.008H9.75v-.008zM7.5 15h.008v.008H7.5V15zm0 2.25h.008v.008H7.5v-.008zM14.25 12h.008v.008H14.25v-.008zm0 2.25h.008v.008H14.25V15zm0 2.25h.008v.008H14.25v-.008zm2.25-4.5h.008v.008H16.5v-.008zm0 2.25h.008v.008H16.5V15z"></path>
            </svg>
            <div>
              <span class="block text-xs font-bold text-[#dcb041] uppercase tracking-widest mb-0.5">Fecha Límite de Recojo</span>
              <span class="text-sm md:text-base font-bold text-white font-serif">Válido para recoger hasta: ${calculateDeadlineDate(redeemedValidity, redeemedDateIso)}</span>
            </div>
          </div>

          <div class="flex items-start gap-3.5">
            <svg class="w-7 h-7 md:w-8 md:h-8 text-[#dcb041] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"></path>
            </svg>
            <div>
              <span class="block text-xs font-bold text-[#dcb041] uppercase tracking-widest mb-0.5">Estado del Beneficio</span>
              <span class="text-xs md:text-sm text-white/80 leading-relaxed font-sans block">Has completado el canje de este beneficio. No se permiten más canjes adicionales hasta que la empresa vuelva a habilitarlo.</span>
            </div>
          </div>
        </div>
      `;
    }

    // 2. Ocultar los demás tickets del grid
    const allWrappers = document.querySelectorAll('.ticket-wrapper');
    allWrappers.forEach(w => {
      if (w !== wrapper) {
        w.style.display = 'none';
      }
    });

    // 3. Transformar contenedor y ticket al Estado Gigante de Recompensa Permanente
    if (container) container.classList.add('estado-recompensa-permanente');
    if (wrapper) {
      wrapper.classList.remove('is-active');
      wrapper.classList.add('ticket-gigante-final', 'is-broken', 'is-stamped');
      
      const btn = ticketElement.querySelector('.btn-redeem');
      if (btn) {
        btn.innerText = "CANJEADO";
        btn.disabled = true;
        btn.style.opacity = "0.5";
        btn.style.cursor = "not-allowed";
      }
    }
  };

  const updateWelcomeBanner = () => {
    const isRegistered = localStorage.getItem('taboada_user_registered') === 'true';
    const userNombre = localStorage.getItem('taboada_user_nombre');
    const titleEl = document.getElementById('community-welcome-title');

    if (isRegistered && userNombre && titleEl) {
      titleEl.innerHTML = `¡Hola, <span class="text-[#dcb041] italic font-semibold">${userNombre}</span>!<br> Bienvenido a la Comunidad Taboada`;
    }
  };

  document.addEventListener('DOMContentLoaded', () => {
    updateWelcomeBanner();
    checkRedeemedState();

    window.addEventListener('taboadaUserRegistered', () => {
      updateWelcomeBanner();
      checkRedeemedState();
    });
  });
</script>

</AppLayout>
