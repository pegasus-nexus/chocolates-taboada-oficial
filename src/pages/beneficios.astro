          href="https://wa.me/59179786916?text=Hola%2C%20quiero%20hacer%20un%20pedido" 
          target="_blank"
          class="w-full py-3 bg-gradient-to-r from-[#dcb041] to-[#f4c856] text-[#2A1612] text-center font-extrabold rounded-full shadow-lg transition-all"
        >
          Pedir Ahora
        </a>
      </div>
    </div>

    <!-- FONDO OSCURO DEL MENÚ MÓVIL -->
    <div
      id="drawer-overlay"
      class="fixed inset-0 z-[998] bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
    ></div>
  </nav>

  <div class="welcome-container">
    
    <!-- Texturas de fondo sutiles -->
    <div class="absolute -right-20 top-1/3 w-96 h-96 bg-gradient-radial from-amber-200/5 to-transparent blur-3xl pointer-events-none"></div>
    <div class="absolute -left-20 top-1/2 w-96 h-96 bg-gradient-radial from-amber-200/5 to-transparent blur-3xl pointer-events-none"></div>

    <!-- BOTÓN DE REGRESO Y FECHA ACTUAL -->
    <div class="top-nav-bar">
      <a href="/" onclick="if(history.length > 1){ history.back(); return false; }" class="btn-back">
        ← Regresar
      </a>
      <div class="current-date-badge">
        📅 {fechaHoy}
      </div>
    </div>

    <header class="welcome-section">
      <div class="flex items-center gap-2 mb-3">
        <span class="w-6 h-[2px] bg-[#dcb041]"></span>
        <span class="text-xs uppercase tracking-widest text-[#dcb041] font-bold font-sans">Comunidad de Lealtad</span>
      </div>
      
      <h1 class="font-serif text-4xl md:text-6xl text-[var(--beige-seda)] font-extrabold leading-tight tracking-tight mb-4">
        Comunidad <span class="text-[#dcb041] italic font-semibold">Taboada</span>
      </h1>
      
      <p style="font-size: 16px; margin-top: 15px; max-width: 600px; line-height: 1.6; color: #e8dccb; font-family: sans-serif;">
        De cortesía elige tu regalo de bienvenida en grande, el cual podrás canjear exclusivamente en nuestra sucursal de 
        <a href="https://n9.cl/cg9lw" target="_blank" rel="noopener noreferrer" style="color: #f6d98d; text-decoration: underline; font-weight: 700;">
           La Recoleta
        </a>.
      </p>
    </header>

    <section class="ticket-container">
      {rewards.map(r => (
        <div class="ticket-wrapper">
          <div class="ticket" id={r.id}>
            
            <div class="stamp-redeemed">CANJEADO</div>

            <div class="ticket-main">
              <div class="ticket-img">
                <img src={r.img} alt={r.title} />
              </div>
              <div class="ticket-info">
                <span class="ticket-tag">{r.tag}</span>
                <h3 class="ticket-title">{r.title}</h3>
                <p class="ticket-desc">{r.desc}</p>
                <div class="ticket-loc">📍 SOLO VÁLIDO PARA LA SUCURSAL RECOLETA · 2026</div>
              </div>
            </div>

            <div class="ticket-divider">
              <div class="hole hole-start"></div>
              <div class="dash-line"></div>
              <div class="hole hole-end"></div>
            </div>

            <div class="ticket-stub">
              <div class="stub-barcode">|||| || |||</div>
              <span class="stub-label">VALIDEZ: {r.validity}</span>
              <button class="btn-redeem" onclick={`abrirModal('${r.id}')`}>CANJEAR</button>
            </div>

          </div>
        </div>
      ))}
    </section>
  </div>

  <!-- ── FOOTER PRINCIPAL COMPLETO CON HORARIOS DE ATENCIÓN Y CONTACTO ── -->
  <Footer />

</div>

<!-- MODAL CAPTACIÓN -->
<div id="modal-captacion" class="modal-overlay">
  <div class="modal-card">
    <h3>Verifica tu Identidad</h3>
    <p>Para asegurar que este beneficio exclusivo llegue a tus manos, completa tus datos.</p>
    
    <form id="form-canje">
      <div class="glass-field">
        <label>Nombre</label>
        <input type="text" id="user-nombre" required placeholder="Ej. Sahian" />
      </div>
      <div class="glass-field">
        <label>Apellido</label>
        <input type="text" id="user-apellido" required placeholder="Ej. Mariné" />
      </div>
      <div class="glass-field">
        <label>Correo Electrónico</label>
        <input type="email" id="user-email" required placeholder="sahian@email.com" />
      </div>
      
      <button type="submit" class="btn-submit-modal">Confirmar y Canjear</button>
      <button type="button" class="btn-cancel-modal" onclick="cerrarModal()">Cancelar</button>
    </form>
  </div>
</div>

<script is:inline>
  let ticketSeleccionado = null;

  function abrirModal(id) {
    const container = document.querySelector('.ticket-container');
    if(container.classList.contains('juego-terminado')) return; 

    ticketSeleccionado = id;
    const modal = document.getElementById('modal-captacion');
    modal.style.display = 'flex';
    setTimeout(() => { modal.classList.add('show'); }, 10);
  }

  function cerrarModal() {
    const modal = document.getElementById('modal-captacion');
    modal.classList.remove('show');
    setTimeout(() => { modal.style.display = 'none'; }, 400);
  }

  document.addEventListener('DOMContentLoaded', () => {
    // ── INTERACCIONES DE NAVBAR Y CIUDAD ──
    const citySelectorBtn = document.getElementById('city-selector-btn');
    const cityDropdown = document.getElementById('city-dropdown');
    const activeCityName = document.getElementById('active-city-name');
    const cityOptButtons = document.querySelectorAll('.city-opt-btn');

    const savedCity = localStorage.getItem('selected_city');
    if (savedCity && activeCityName) {
      activeCityName.textContent = savedCity === 'la-paz' ? 'La Paz' : 'Cochabamba';
    }

    citySelectorBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      cityDropdown?.classList.toggle('hidden');
    });

    document.addEventListener('click', () => {
      cityDropdown?.classList.add('hidden');
    });

    cityOptButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const selected = btn.getAttribute('data-city') || 'cochabamba';
        localStorage.setItem('selected_city', selected);
        if (activeCityName) {
          activeCityName.textContent = selected === 'la-paz' ? 'La Paz' : 'Cochabamba';
        }
      });
    });

    // ── MENÚ MÓVIL (DRAWER) ──
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileCloseBtn = document.getElementById('mobile-close-btn');
    const mobileDrawer = document.getElementById('mobile-drawer');
    const drawerOverlay = document.getElementById('drawer-overlay');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    function openDrawer() {
      mobileDrawer?.classList.remove('translate-x-full');
      drawerOverlay?.classList.remove('opacity-0', 'pointer-events-none');
    }

    function closeDrawer() {
      mobileDrawer?.classList.add('translate-x-full');
      drawerOverlay?.classList.add('opacity-0', 'pointer-events-none');
    }

    mobileMenuBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      openDrawer();
    });

    mobileCloseBtn?.addEventListener('click', closeDrawer);
    drawerOverlay?.addEventListener('click', closeDrawer);
    mobileLinks.forEach((link) => link.addEventListener('click', closeDrawer));

    // ── FORMULARIO DE CANJE DE TICKETS ──
    const formCanje = document.getElementById('form-canje');
    if(formCanje) {
      formCanje.addEventListener('submit', (e) => {
        e.preventDefault(); 
        cerrarModal(); 

        if(!ticketSeleccionado) return; 

        const container = document.querySelector('.ticket-container');
        container.classList.add('juego-terminado');

        const ticketElement = document.getElementById(ticketSeleccionado);
        if(!ticketElement) return;

        const wrapper = ticketElement.closest('.ticket-wrapper');
        const btn = ticketElement.querySelector('.btn-redeem');
        if(btn) btn.innerText = "VALIDANDO...";

        wrapper.classList.add('is-active');

        setTimeout(() => { wrapper.classList.add('is-broken'); }, 800);
        setTimeout(() => { wrapper.classList.add('is-stamped'); }, 1400);
        setTimeout(() => { alert("¡Beneficio validado exitosamente! Muestra esta pantalla en caja."); }, 2200);
      });
    }
  });
</script>

</AppLayout>
