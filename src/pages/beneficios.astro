  },
  { 
    id:'c3', 
    name:'PACK GRAGEAS PREMIUN',    
    desc:'Macarrón, Arroz y Maní con chocolate blanco', 
    price:'Bs 54', 
    img:'/img/produc3.png'  
  },
  { 
    id:'c4', 
    name:'PACK TABLETAS CÍTRICO',    
    desc:'Naranja, Uvas pasas y chocolate Semi-Amargo', 
    price:'Bs 75', 
    img:'/img/tableta1.png' 
  },
  { 
    id:'c5', 
    name:'PACK TABLETAS TROPICAL',   
    desc:'Amaranto, Coco y Frutilla', 
    price:'Bs 75', 
    img:'/img/tableta2.png' 
  },
  { 
    id:'c6', 
    name:'PACK TABLETAS ANDINO',     
    desc:'Quinua, Chocolate Blanco y Menta', 
    price:'Bs 75', 
