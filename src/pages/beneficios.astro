  },
];

// 3. Datos de sucursales
const sucursales = [
  { ciudad: 'Cochabamba', locales: [
    { nombre: 'Boutique La Recoleta', dir: 'Av. Potosí, Zona La Recoleta' },
    { nombre: 'Punto Heroínas', dir: 'Calle Heroínas, Centro Histórico' }
  ]},
  { ciudad: 'La Paz', locales: [
    { nombre: 'Boutique Calacoto', dir: 'Zona Calacoto, Calle 15' }
  ]}
];
---

<AppLayout title="Club Taboada · Beneficios">

<style is:global>
  :root {
    --oro-viejo: #8f6c49;
    --beige-seda: #FAF5F0;
    --cafe-profundo: #2A1612;
    --font-serif: "Playfair Display", serif; 
  }

  body { background-color: var(--beige-seda); color: var(--cafe-profundo); margin: 0; }

  /* ── HEADER FIJO (Igual al principal) ── */
  .fixed-header {
    position: fixed;
    top: 0; left: 0; width: 100%;
    padding: 15px 5%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 100;
    background-color: rgba(250, 245, 240, 0.85);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border-bottom: 1px solid rgba(42, 22, 18, 0.08);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.02);
  }
  .logo-main { height: clamp(40px, 6vw, 60px); } 

  /* ── SECCIÓN DE BIENVENIDA ── */
  .welcome-container {
    position: relative;
    min-height: 100vh;
    padding: 140px 5% 80px;
    display: flex;
    flex-direction: column;
    background-color: var(--beige-seda);
  }

  .welcome-section {
    text-align: left;
    max-width: 1200px;
    margin: 0 auto 40px;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  /* ── SECCIÓN DE TICKETS OSCUROS LUXURY ── */
  .ticket-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 20px auto 40px;
    width: 100%;
    position: relative;
    z-index: 10;
  }

  .ticket-wrapper {
    position: relative;
    filter: drop-shadow(0 15px 30px rgba(42, 22, 18, 0.15));
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    height: fit-content;
  }
  .ticket-wrapper:hover { transform: translateY(-4px) scale(1.01); }

  .ticket {
    background: linear-gradient(135deg, #2A1612 0%, #1A0A0C 100%);
    display: flex;
    flex-direction: row; 
    border-radius: 24px;
    overflow: hidden;
    position: relative;
    border: 1px solid rgba(255,255,255,0.05);
  }

  .ticket-main, .ticket-stub, .ticket-divider { transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.5s ease; }
  .ticket-main { flex: 1; padding: 28px; display: flex; align-items: center; gap: 20px; }
  .ticket-img { width: 85px; height: 85px; background: rgba(255,255,255,0.05); border-radius: 20px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border: 1px solid rgba(255, 255, 255, 0.1); }
  .ticket-img img { max-width: 80%; max-height: 80%; object-fit: contain; filter: drop-shadow(0 5px 15px rgba(0,0,0,0.3)); }

  .ticket-info { text-align: left; }
  .ticket-tag { font-size: 9px; font-weight: 800; color: #f6d98d; letter-spacing: 0.15em; text-transform: uppercase; }
  .ticket-title { font-family: var(--font-serif); font-size: 1.5rem; color: #ffffff; margin: 4px 0; font-weight: bold; }
  .ticket-desc { font-size: 11px; color: #e8dccb; opacity: 0.85; margin-bottom: 8px; line-height: 1.4; font-family: sans-serif; }
  .ticket-loc { font-size: 8px; font-weight: 700; color: #FAF5F0; opacity: 0.5; letter-spacing: 0.05em; }

  .ticket-divider { position: relative; display: flex; align-items: center; justify-content: center; width: 2px; }
  .dash-line { width: 2px; height: 100%; border-left: 2px dashed rgba(255, 255, 255, 0.15); }
  .hole { position: absolute; width: 28px; height: 28px; background-color: var(--beige-seda); border-radius: 50%; z-index: 5; }
  .hole-start { top: -14px; left: -13px; }
  .hole-end { bottom: -14px; left: -13px; }

  .ticket-stub { width: 130px; background: rgba(255,255,255,0.02); display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px 15px; text-align: center; border-left: 1px solid rgba(255,255,255,0.05); }
  .stub-barcode { font-family: monospace; font-size: 18px; font-weight: 500; color: #ffffff; opacity: 0.3; letter-spacing: 1px; margin-bottom: 8px; }
  .stub-label { font-size: 8px; font-weight: 700; color: #f6d98d; margin-bottom: 12px; letter-spacing: 0.05em; }

  .btn-redeem { background: #FAF5F0; color: var(--cafe-profundo); border: none; padding: 10px 15px; border-radius: 9999px; font-size: 10px; font-weight: 800; cursor: pointer; transition: all 0.3s ease; letter-spacing: 0.08em; width: 100%; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
  .btn-redeem:hover { background: #8f6c49; color: #ffffff; transform: translateY(-1px); }
  .btn-redeem:active { transform: scale(0.97); }

  .stamp-redeemed {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(4) rotate(-25deg);
    font-family: var(--font-serif); font-size: 2.2rem; color: #3a1823; border: 3px solid #3a1823;
    padding: 8px 20px; border-radius: 12px; font-weight: 900; opacity: 0; z-index: 100; transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    background: #FAF5F0; pointer-events: none; box-shadow: 0 10px 25px rgba(0,0,0,0.3);
  }

  /* ── ANIMACIONES DE JUEGO ── */
  .ticket-container.juego-terminado .ticket-wrapper:not(.is-active) { display: none; }
  .ticket-container.juego-terminado { display: flex; justify-content: center; align-items: center; }
  .ticket-wrapper.is-active { transform: scale(1.1); z-index: 50; pointer-events: none; }
  .ticket-wrapper.is-broken .ticket-main { transform: translateX(-15px) rotate(-2deg); opacity: 0.9; }
  .ticket-wrapper.is-broken .ticket-stub { transform: translateX(15px) rotate(2deg); opacity: 0.9; }
  .ticket-wrapper.is-broken .ticket-divider { opacity: 0; }
  .ticket-wrapper.is-stamped .stamp-redeemed { opacity: 1; transform: translate(-50%, -50%) scale(1) rotate(-12deg); }

  /* ── SECCIÓN GALERÍA PRODUCTOS (Colección FEXCO) ── */
  .gallery-section { padding: 100px 24px; background: #FAF8F3; text-align: center; border-radius: 50px 50px 0 0; border-top: 1px solid #e8dccb; position: relative; z-index: 2; color: var(--cafe-profundo); }
  .gallery-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px; max-width: 1200px; margin: 40px auto 60px;
  }
  .lux-card { background: white; padding: 30px; border-radius: 2rem; border: 1px solid #e8dccb; box-shadow: 0 4px 20px rgba(42, 22, 18, 0.03); text-align: center; transition: all 0.4s ease; }
  .lux-card:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(42, 22, 18, 0.08); }
  .lux-card img { max-height: 160px; width: auto; margin-bottom: 20px; object-fit: contain; filter: drop-shadow(0 10px 15px rgba(42, 22, 18, 0.1)); }
  .lux-card h3 { font-family: var(--font-serif); color: var(--cafe-profundo); font-size: 1.3rem; margin-bottom: 8px; font-weight: bold; }
  .lux-card p { color: #6b5855; font-size: 0.85rem; line-height: 1.5; margin-bottom: 20px; font-family: sans-serif; }
  .lux-price { color: var(--oro-viejo); font-weight: 800; font-size: 1.3rem; font-family: var(--font-serif); }

  /* ── FOOTER ELEGANT (Mismo al del principal) ── */
  .footer-info { background: #1A0A0C; padding: 80px 24px; color: var(--beige-seda); text-align: center; border-top: 1px solid rgba(196, 167, 125, 0.1); }
  .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 40px; max-width: 1000px; margin: 0 auto 50px; }
  .footer-city { color: #f6d98d; text-transform: uppercase; letter-spacing: 0.15em; font-weight: 700; margin-bottom: 20px; font-size: 0.85rem; }
  .footer-local { margin-bottom: 15px; }
  .footer-local strong { display: block; font-family: var(--font-serif); font-size: 1.05rem; margin-bottom: 4px; }
  .footer-local span { opacity: 0.65; font-size: 0.85rem; }

  .social-links { display: flex; justify-content: center; gap: 20px; }
  .social-links a { color: #f6d98d; text-decoration: none; font-weight: 700; font-size: 0.75rem; letter-spacing: 0.1em; transition: opacity 0.3s; }
  .social-links a:hover { opacity: 0.8; }

  /* ── MODAL CAPTACIÓN ── */
  .modal-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100vh;
    background: rgba(42, 22, 18, 0.6); 
    backdrop-filter: blur(15px); 
    -webkit-backdrop-filter: blur(15px); 
    display: none; justify-content: center; align-items: center; z-index: 1000;
    opacity: 0; transition: opacity 0.4s ease;
  }
  .modal-overlay.show { opacity: 1; }
  .modal-card { background: #1C0D0E; border: 1px solid rgba(196, 167, 125, 0.2); padding: 40px; border-radius: 2rem; width: 90%; max-width: 400px; box-shadow: 0 25px 60px rgba(0,0,0,0.4); text-align: center; transform: translateY(20px); transition: transform 0.3s ease; }
  .modal-overlay.show .modal-card { transform: translateY(0); }
  .modal-card h3 { font-family: var(--font-serif); color: #f6d98d; font-size: 1.6rem; margin-bottom: 6px; font-weight: bold; }
  .modal-card p { color: #e8dccb; font-size: 12px; margin-bottom: 25px; line-height: 1.5; }
  .glass-field { margin-bottom: 18px; text-align: left; }
  .glass-field label { color: #f6d98d; font-size: 9px; font-weight: 800; text-transform: uppercase; margin-bottom: 6px; display: block; letter-spacing: 0.05em; }
  .glass-field input { background: rgba(255, 255, 255, 0.05) !important; border: 1px solid rgba(255,255,255,0.1) !important; padding: 14px !important; color: #fff !important; border-radius: 12px !important; width: 100%; font-size: 14px; box-sizing: border-box; transition: border-color 0.3s; }
  .glass-field input:focus { outline: none; border-color: #8f6c49 !important; }
  .btn-submit-modal { width: 100%; padding: 15px; background: linear-gradient(145deg, #f6d98d, #dcb041); color: #2e1119; font-weight: 800; border: none; border-radius: 9999px; cursor: pointer; text-transform: uppercase; margin-top: 15px; transition: all 0.3s; font-size: 12px; letter-spacing: 0.05em; box-shadow: 0 10px 20px rgba(220,176,65,0.2); }
  .btn-submit-modal:hover { transform: translateY(-1px); box-shadow: 0 12px 24px rgba(220,176,65,0.3); }
  .btn-cancel-modal { background: transparent; color: rgba(255,255,255,0.4); border: none; font-size: 10px; text-decoration: underline; cursor: pointer; margin-top: 15px; text-transform: uppercase; letter-spacing: 0.05em; }

  @media (max-width: 650px) {
    .ticket-container { grid-template-columns: 1fr; }
    .ticket-main { padding: 20px; gap: 12px; }
    .ticket-img { width: 65px; height: 65px; border-radius: 12px; }
    .ticket-tag { font-size: 7.5px; }
    .ticket-title { font-size: 1.25rem; }
    .ticket-desc { display: none; } 
    .ticket-stub { width: 105px; padding: 15px 10px; }
    .stub-barcode { font-size: 14px; }
    .stub-label { font-size: 7.5px; }
    .btn-redeem { padding: 8px 4px; font-size: 8.5px; }
    .hole { width: 22px; height: 22px; }
    .hole-start { top: -11px; left: -10px; }
    .hole-end { bottom: -11px; left: -10px; }
  }
</style>

<div id="page-root">
  <!-- HEADER FIJO -->
  <div class="fixed-header">
    <a href="/">
      <img 
        src="/img/taboada-logo.png" 
        alt="Chocolates Taboada" 
        class="logo-main" 
      />  
    </a>
  </div>

  <div class="welcome-container">
    
    <!-- Textures watermarks like the main page -->
    <div class="absolute -right-20 top-1/3 w-96 h-96 bg-gradient-radial from-amber-200/5 to-transparent blur-3xl pointer-events-none"></div>
    <div class="absolute -left-20 top-1/2 w-96 h-96 bg-gradient-radial from-amber-200/5 to-transparent blur-3xl pointer-events-none"></div>

    <header class="welcome-section">
      <div class="flex items-center gap-2 mb-3">
        <span class="w-6 h-[2px] bg-[#8f6c49]"></span>
        <span class="text-xs uppercase tracking-widest text-[#8f6c49] font-bold font-sans">Comunidad de Lealtad</span>
      </div>
      
      <h1 class="font-serif text-4xl md:text-6xl text-[#2A1612] font-extrabold leading-tight tracking-tight mb-4">
        Club <span class="text-[#8f6c49] italic font-semibold">Taboada</span>
      </h1>
      
      <p style="font-size: 16px; margin-top: 15px; max-width: 600px; line-height: 1.6; color: #5D4037; font-family: sans-serif;">
        De cortesía elige tu regalo de bienvenida en grande, el cual podrás canjear exclusivamente en nuestra sucursal de 
        <a href="https://n9.cl/cg9lw" target="_blank" rel="noopener noreferrer" style="color: var(--oro-viejo); text-decoration: underline; font-weight: 700;">
          La Recoleta
        </a>.
      </p>
    </header>

    <section class="ticket-container">
      {rewards.map(r => (
        <div class="ticket-wrapper">
          <div class="ticket" id={r.id}>
            
            <div class="stamp-redeemed">CANJEADO</div>

            <div class="ticket-main">
              <div class="ticket-img">
                <img src={r.img} alt={r.title} />
              </div>
              <div class="ticket-info">
                <span class="ticket-tag">{r.tag}</span>
                <h3 class="ticket-title">{r.title}</h3>
                <p class="ticket-desc">{r.desc}</p>
                <div class="ticket-loc">📍 SOLO VÁLIDO PARA LA SUCURSAL RECOLETA · 2026</div>
              </div>
            </div>

            <div class="ticket-divider">
              <div class="hole hole-start"></div>
              <div class="dash-line"></div>
              <div class="hole hole-end"></div>
            </div>

            <div class="ticket-stub">
              <div class="stub-barcode">|||| || |||</div>
              <span class="stub-label">VALIDEZ: {r.validity}</span>
              <button class="btn-redeem" onclick={`abrirModal('${r.id}')`}>CANJEAR</button>
            </div>

          </div>
        </div>
      ))}
    </section>
  </div>

  

  <footer class="footer-info">
    <h2 style="font-family: var(--font-serif); font-size: 2rem; margin-bottom: 50px;">Nuestras Boutiques</h2>
    <div class="footer-grid">
      {sucursales.map(s => (
        <div>
          <div class="footer-city">{s.ciudad}</div>
          {s.locales.map(l => (
            <div class="footer-local">
              <strong>{l.nombre}</strong>
              <span>{l.dir}</span>
            </div>
          ))}
        </div>
      ))}
    </div>

    <div class="social-links">
      <a href="#">FACEBOOK</a>
      <a href="#">INSTAGRAM</a>
      <a href="#">TIKTOK</a>
      <a href="#">WHATSAPP</a>
    </div>
    
    <p style="margin-top: 60px; font-size: 10px; opacity: 0.4; letter-spacing: 0.1em;">© 2026 CHOCOLATES TABOADA · DESDE 1903</p>
  </footer>
</div>

<div id="modal-captacion" class="modal-overlay">
  <div class="modal-card">
    <h3>Verifica tu Identidad</h3>
    <p>Para asegurar que este beneficio exclusivo llegue a tus manos, completa tus datos.</p>
    
    <form id="form-canje">
      <div class="glass-field">
        <label>Nombre</label>
        <input type="text" id="user-nombre" required placeholder="Ej. Sahian" />
      </div>
      <div class="glass-field">
        <label>Apellido</label>
        <input type="text" id="user-apellido" required placeholder="Ej. Mariné" />
      </div>
      <div class="glass-field">
        <label>Correo Electrónico</label>
        <input type="email" id="user-email" required placeholder="sahian@email.com" />
      </div>
      
      <button type="submit" class="btn-submit-modal">Confirmar y Canjear</button>
      <button type="button" class="btn-cancel-modal" onclick="cerrarModal()">Cancelar</button>
    </form>
  </div>
</div>

<script is:inline>
  let ticketSeleccionado = null;

  function abrirModal(id) {
    const container = document.querySelector('.ticket-container');
    if(container.classList.contains('juego-terminado')) return; 

    ticketSeleccionado = id;
    const modal = document.getElementById('modal-captacion');
    modal.style.display = 'flex';
    setTimeout(() => { modal.classList.add('show'); }, 10);
  }

  function cerrarModal() {
    const modal = document.getElementById('modal-captacion');
    modal.classList.remove('show');
    setTimeout(() => { modal.style.display = 'none'; }, 400);
  }

  document.addEventListener('DOMContentLoaded', () => {
    const formCanje = document.getElementById('form-canje');
    
    if(formCanje) {
      formCanje.addEventListener('submit', (e) => {
        e.preventDefault(); 
        cerrarModal(); 

        if(!ticketSeleccionado) return; 

        const container = document.querySelector('.ticket-container');
        container.classList.add('juego-terminado');

        const ticketElement = document.getElementById(ticketSeleccionado);
        if(!ticketElement) return;

        const wrapper = ticketElement.closest('.ticket-wrapper');
        const btn = ticketElement.querySelector('.btn-redeem');
        if(btn) btn.innerText = "VALIDANDO...";

        wrapper.classList.add('is-active');

        setTimeout(() => { wrapper.classList.add('is-broken'); }, 800);
        setTimeout(() => { wrapper.classList.add('is-stamped'); }, 1400);
        setTimeout(() => { alert("¡Beneficio validado exitosamente! Muestra esta pantalla en caja."); }, 2200);
      });
    }
  });
</script>

</AppLayout>
