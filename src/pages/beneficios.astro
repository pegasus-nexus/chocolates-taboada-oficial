---
import AppLayout from '../layouts/AppLayout.astro';
import Footer from '../components/Footer.astro';

// 1. Datos de los beneficios con VALIDEZ PERSONALIZADA e imágenes corregidas
const rewards = [
  { id:'trufa', title:'Chocolate Amargo', tag:'Regalo VIP', desc:'Pieza maestra de cacao belga.', img:'/img/razon2.png', validity: '2 Semanas' },
  { id:'choco', title:'Trufas de Chocolate', tag:'Exclusivo', desc:'70% cacao amazónico.', img:'/img/especial1.png', validity: '2 Semanas' },
  { id:'cupon2', title:'Gesto 2%', tag:'Cortesía', desc:'Descuento especial de bienvenida.', img:'/img/taboada-logo.png', validity: 'Un mes' },
  { id:'choco3', title:'Gesto 3%', tag:'Exclusivo', desc:'70% cacao amazónico en tu compra.', img:'/img/taboada-logo.png', validity: '2 Semanas' },
  { id:'cupon4', title:'Gesto 4%', tag:'Cortesía', desc:'Descuento especial por compras.', img:'/img/taboada-logo.png', validity: '1 Semana' },
];

// Fecha actual formateada
const fechaHoy = new Date().toLocaleDateString('es-ES', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<AppLayout title="Comunidad Taboada · Beneficios Exclusivos">

<style is:global>
  :root {
    --oro-viejo: #8f6c49;
    --beige-seda: #FAF5F0;
    --cafe-profundo: #2A1612;
    --font-serif: "Playfair Display", serif; 
  }

  body { background-color: var(--cafe-profundo); color: var(--beige-seda); margin: 0; }

  /* ── SECCIÓN DE BIENVENIDA (Fondo Café Profundo) ── */
  .welcome-container {
    position: relative;
    min-height: 100vh;
    padding: 130px 5% 80px;
    display: flex;
    flex-direction: column;
    background-color: var(--cafe-profundo);
  }

  /* ── BARRA SUPERIOR CON BOTÓN DE REGRESO Y FECHA ── */
  .top-nav-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto 30px;
    width: 100%;
    position: relative;
    z-index: 10;
  }

  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border-radius: 9999px;
    background: rgba(250, 245, 240, 0.08);
    color: var(--beige-seda);
    text-decoration: none;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid rgba(250, 245, 240, 0.15);
    backdrop-filter: blur(10px);
    transition: all 0.3s ease;
  }

  .btn-back:hover {
    background: var(--oro-viejo);
    color: #ffffff;
    border-color: var(--oro-viejo);
    transform: translateX(-3px);
  }

  .current-date-badge {
    font-size: 11px;
    color: rgba(250, 245, 240, 0.75);
    font-weight: 600;
    text-transform: capitalize;
    letter-spacing: 0.05em;
    font-family: sans-serif;
    background: rgba(255, 255, 255, 0.04);
    padding: 6px 14px;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .welcome-section {
    text-align: left;
    max-width: 1200px;
    margin: 0 auto 40px;
    width: 100%;
    position: relative;
    z-index: 2;
  }

 /* ── SECCIÓN DE TICKETS CLAROS (Fondo Beige / Texto Oscuro) ── */
  .ticket-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 20px auto 40px;
    width: 100%;
    position: relative;
    z-index: 10;
  }

  .ticket-wrapper {
    position: relative;
    filter: drop-shadow(0 15px 30px rgba(0, 0, 0, 0.35));
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    height: fit-content;
  }
  .ticket-wrapper:hover { transform: translateY(-4px) scale(1.01); }

  .ticket {
    background: linear-gradient(135deg, #FAF5F0 0%, #F3ECE3 100%);
    display: flex;
    flex-direction: row; 
    border-radius: 24px;
    overflow: hidden;
    position: relative;
    border: none; /* Borde exterior eliminado */
  }

  .ticket-main, .ticket-stub, .ticket-divider { transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.5s ease; }
  .ticket-main { flex: 1; padding: 28px; display: flex; align-items: center; gap: 20px; }
  
  .ticket-img { 
    width: 85px; 
    height: 85px; 
    background: rgba(42, 22, 18, 0.05); 
    border-radius: 20px; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    flex-shrink: 0; 
    border: none; /* Borde de la imagen eliminado */ 
  }
  .ticket-img img { max-width: 80%; max-height: 80%; object-fit: contain; filter: drop-shadow(0 5px 15px rgba(0,0,0,0.15)); }

  .ticket-info { text-align: left; }
  .ticket-tag { font-size: 9px; font-weight: 800; color: #8f6c49; letter-spacing: 0.15em; text-transform: uppercase; }
  .ticket-title { font-family: var(--font-serif); font-size: 1.5rem; color: #2A1612; margin: 4px 0; font-weight: bold; }
  .ticket-desc { font-size: 11px; color: #5D4037; opacity: 0.9; margin-bottom: 8px; line-height: 1.4; font-family: sans-serif; }
  .ticket-loc { font-size: 8px; font-weight: 700; color: #8f6c49; opacity: 0.75; letter-spacing: 0.05em; }

  .ticket-divider { position: relative; display: flex; align-items: center; justify-content: center; width: 2px; }
  .dash-line { width: 2px; height: 100%; border-left: 2px dashed rgba(42, 22, 18, 0.2); }
  .hole { position: absolute; width: 28px; height: 28px; background-color: var(--cafe-profundo); border-radius: 50%; z-index: 5; }
  .hole-start { top: -14px; left: -13px; }
  .hole-end { bottom: -14px; left: -13px; }

  .ticket-stub { 
    width: 130px; 
    background: rgba(42, 22, 18, 0.03); 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    justify-content: center; 
    padding: 20px 15px; 
    text-align: center; 
    border-left: none; /* Borde interno eliminado */ 
  }
  .stub-barcode { font-family: monospace; font-size: 18px; font-weight: 500; color: #2A1612; opacity: 0.45; letter-spacing: 1px; margin-bottom: 8px; }
  .stub-label { font-size: 8px; font-weight: 700; color: #8f6c49; margin-bottom: 12px; letter-spacing: 0.05em; }

  .btn-redeem { background: var(--cafe-profundo); color: var(--beige-seda); border: none; padding: 10px 15px; border-radius: 9999px; font-size: 10px; font-weight: 800; cursor: pointer; transition: all 0.3s ease; letter-spacing: 0.08em; width: 100%; box-shadow: 0 4px 10px rgba(42, 22, 18, 0.2); }
  .btn-redeem:hover { background: #8f6c49; color: #ffffff; transform: translateY(-1px); }
  .btn-redeem:active { transform: scale(0.97); }

  .stamp-redeemed {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) scale(4) rotate(-25deg);
    font-family: var(--font-serif); font-size: 2.2rem; color: #3a1823; border: 3px solid #3a1823;
    padding: 8px 20px; border-radius: 12px; font-weight: 900; opacity: 0; z-index: 100; transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    background: #FAF5F0; pointer-events: none; box-shadow: 0 10px 25px rgba(0,0,0,0.3);
  }

  /* ── ANIMACIONES DE JUEGO ── */
  .ticket-container.juego-terminado .ticket-wrapper:not(.is-active) { display: none; }
  .ticket-container.juego-terminado { display: flex; justify-content: center; align-items: center; }
  .ticket-wrapper.is-active { transform: scale(1.1); z-index: 50; pointer-events: none; }
  .ticket-wrapper.is-broken .ticket-main { transform: translateX(-15px) rotate(-2deg); opacity: 0.9; }
  .ticket-wrapper.is-broken .ticket-stub { transform: translateX(15px) rotate(2deg); opacity: 0.9; }
  .ticket-wrapper.is-broken .ticket-divider { opacity: 0; }
  .ticket-wrapper.is-stamped .stamp-redeemed { opacity: 1; transform: translate(-50%, -50%) scale(1) rotate(-12deg); }

  /* ── MODAL CAPTACIÓN ── */
  .modal-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100vh;
    background: rgba(42, 22, 18, 0.75); 
    backdrop-filter: blur(15px); 
    -webkit-backdrop-filter: blur(15px); 
    display: none; justify-content: center; align-items: center; z-index: 1000;
    opacity: 0; transition: opacity 0.4s ease;
  }
  .modal-overlay.show { opacity: 1; }
  .modal-card { background: #1C0D0E; border: 1px solid rgba(196, 167, 125, 0.2); padding: 40px; border-radius: 2rem; width: 90%; max-width: 400px; box-shadow: 0 25px 60px rgba(0,0,0,0.4); text-align: center; transform: translateY(20px); transition: transform 0.3s ease; }
  .modal-overlay.show .modal-card { transform: translateY(0); }
  .modal-card h3 { font-family: var(--font-serif); color: #f6d98d; font-size: 1.6rem; margin-bottom: 6px; font-weight: bold; }
  .modal-card p { color: #e8dccb; font-size: 12px; margin-bottom: 25px; line-height: 1.5; }
  .glass-field { margin-bottom: 18px; text-align: left; }
  .glass-field label { color: #f6d98d; font-size: 9px; font-weight: 800; text-transform: uppercase; margin-bottom: 6px; display: block; letter-spacing: 0.05em; }
  .glass-field input { background: rgba(255, 255, 255, 0.05) !important; border: 1px solid rgba(255,255,255,0.1) !important; padding: 14px !important; color: #fff !important; border-radius: 12px !important; width: 100%; font-size: 14px; box-sizing: border-box; transition: border-color 0.3s; }
  .glass-field input:focus { outline: none; border-color: #8f6c49 !important; }
  .btn-submit-modal { width: 100%; padding: 15px; background: linear-gradient(145deg, #f6d98d, #dcb041); color: #2e1119; font-weight: 800; border: none; border-radius: 9999px; cursor: pointer; text-transform: uppercase; margin-top: 15px; transition: all 0.3s; font-size: 12px; letter-spacing: 0.05em; box-shadow: 0 10px 20px rgba(220,176,65,0.2); }
  .btn-submit-modal:hover { transform: translateY(-1px); box-shadow: 0 12px 24px rgba(220,176,65,0.3); }
  .btn-cancel-modal { background: transparent; color: rgba(255,255,255,0.4); border: none; font-size: 10px; text-decoration: underline; cursor: pointer; margin-top: 15px; text-transform: uppercase; letter-spacing: 0.05em; }

  @media (max-width: 650px) {
    .ticket-container { grid-template-columns: 1fr; }
    .ticket-main { padding: 20px; gap: 12px; }
    .ticket-img { width: 65px; height: 65px; border-radius: 12px; }
    .ticket-tag { font-size: 7.5px; }
    .ticket-title { font-size: 1.25rem; }
    .ticket-desc { display: none; } 
    .ticket-stub { width: 105px; padding: 15px 10px; }
    .stub-barcode { font-size: 14px; }
    .stub-label { font-size: 7.5px; }
    .btn-redeem { padding: 8px 4px; font-size: 8.5px; }
    .hole { width: 22px; height: 22px; }
    .hole-start { top: -11px; left: -10px; }
    .hole-end { bottom: -11px; left: -10px; }
  }
</style>

<div id="page-root">
  
  <!-- ── NAVBAR COMPLETO IDÉNTICO AL PRINCIPAL (Fondo Café Profundo) ── -->
