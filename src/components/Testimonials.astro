---
---
<section class="testimonials">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Comunidad</span>
      <h2>Nuestros Clientes Opinan</h2>
      <p>Comparte tu experiencia con Chocolates Taboada o lee las opiniones de la comunidad.</p>
    </div>

    <!-- Lista de Comentarios -->
    <div id="comments-list" class="testimonials-grid">
      <article class="testimonial-card">
        <div class="stars">★★★★★</div>
        <p>“Excelente calidad, los bombones tienen un sabor único. Totalmente recomendado.”</p>
        <span class="comment-author">— María Fernanda S.</span>
      </article>
      <article class="testimonial-card">
        <div class="stars">★★★★★</div>
        <p>“La presentación parecía de marca internacional. Muy elegante y orgullosamente boliviano.”</p>
        <span class="comment-author">— Alejandro T.</span>
      </article>
      <article class="testimonial-card">
        <div class="stars">★★★★★</div>
        <p>“Un sabor exquisito y una presentación de exportación. Sucre tiene el mejor chocolate.”</p>
        <span class="comment-author">— Jimena R.</span>
      </article>
    </div>

    <!-- Formulario para dejar comentario -->
    <div class="comment-form-container">
      <h3>Comparte tu comentario</h3>
      <form id="comment-form">
        <div class="form-grid">
          <div class="input-group">
            <label for="comment-name">Nombre</label>
            <input type="text" id="comment-name" placeholder="Ej. Juan Pérez" required />
          </div>
          <div class="input-group">
            <label for="comment-stars">Calificación</label>
            <select id="comment-stars">
              <option value="★★★★★">★★★★★ (5 estrellas)</option>
              <option value="★★★★">★★★★ (4 estrellas)</option>
              <option value="★★★">★★★ (3 estrellas)</option>
              <option value="★★">★★ (2 estrellas)</option>
              <option value="★">★ (1 estrella)</option>
            </select>
          </div>
        </div>
        <div class="input-group">
          <label for="comment-text">Tu Comentario</label>
          <textarea id="comment-text" placeholder="Escribe aquí tu opinión sobre Chocolates Taboada..." rows="3" required></textarea>
        </div>
        <button type="submit" class="submit-comment-btn">Enviar Comentario</button>
      </form>
    </div>
  </div>
</section>

<style>
  section {
    padding: 92px 20px;
  }

  .testimonials {
    background: #FAF5F0;
    border-top: 1px solid #e8dccb;
  }

  .container {
    width: min(1120px, 100%);
    margin: 0 auto;
  }

  .section-head {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 48px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 700;
    font-size: 0.76rem;
    color: #8f6c49;
    justify-content: center;
    width: 100%;
  }

  .eyebrow::before {
    content: "";
    width: 34px;
    height: 1px;
    background: #8f6c49;
  }

  .section-head h2 {
    font-family: 'Playfair Display', serif;
    margin: 0;
    line-height: 1.1;
    font-size: clamp(2.35rem, 5vw, 3.5rem);
    color: #2A1612;
    font-weight: bold;
    letter-spacing: -0.02em;
  }

  .section-head p {
    margin: 18px auto 0;
    font-size: 1rem;
    line-height: 1.7;
    color: #5D4037;
    opacity: 0.85;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    margin-bottom: 50px;
  }

  .testimonial-card {
    border: 1px solid #e8dccb;
    background: #ffffff;
    border-radius: 24px;
    padding: 28px;
    box-shadow: 0 10px 30px rgba(42, 22, 18, 0.02);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.3s ease;
    animation: fadeInUp 0.5s ease forwards;
  }
  .testimonial-card:hover {
    transform: translateY(-2px);
  }

  .stars {
    color: #d4af37;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
    font-size: 0.9rem;
  }

  .testimonial-card p {
    color: #2A1612;
    line-height: 1.6;
    margin: 0 0 16px 0;
    font-size: 0.95rem;
    flex-grow: 1;
  }

  .comment-author {
    font-size: 0.8rem;
    font-weight: 700;
    color: #8f6c49;
    display: block;
  }

  /* Formulario de comentarios */
  .comment-form-container {
    max-width: 650px;
    margin: 0 auto;
    background: #ffffff;
    border: 1px solid #e8dccb;
    border-radius: 2rem;
    padding: 40px;
    box-shadow: 0 15px 40px rgba(42, 22, 18, 0.04);
  }

  .comment-form-container h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    color: #2A1612;
    margin-top: 0;
    margin-bottom: 25px;
    font-weight: bold;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    text-align: left;
    margin-bottom: 20px;
  }

  .input-group label {
    font-size: 9px;
    font-weight: 800;
    text-transform: uppercase;
    color: #2A1612;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }

  .input-group input, 
  .input-group select, 
  .input-group textarea {
    padding: 14px;
    border: 1px solid #e8dccb;
    border-radius: 12px;
    background: #FAF8F3;
    font-family: inherit;
    font-size: 14px;
    color: #2A1612;
    transition: all 0.3s ease;
    box-sizing: border-box;
    width: 100%;
  }

  .input-group input:focus, 
  .input-group select:focus, 
  .input-group textarea:focus {
    outline: none;
    border-color: #8f6c49;
    background: #ffffff;
    box-shadow: 0 0 0 4px rgba(143, 108, 73, 0.1);
  }

  .submit-comment-btn {
    width: 100%;
    padding: 16px;
    background: #2A1612;
    color: #ffffff;
    border: none;
    border-radius: 9999px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.3s;
    font-size: 12px;
    box-shadow: 0 8px 20px rgba(42, 22, 18, 0.15);
  }

  .submit-comment-btn:hover {
    background: #8f6c49;
    transform: translateY(-1px);
    box-shadow: 0 10px 25px rgba(143, 108, 73, 0.25);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 980px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    section {
      padding: 68px 16px;
    }
    .form-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .testimonial-card {
      padding: 24px;
      border-radius: 20px;
    }
    .comment-form-container {
      padding: 30px 20px;
      border-radius: 1.5rem;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('comment-form');
    const commentsList = document.getElementById('comments-list');

    if (form && commentsList) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();

        const nameInput = document.getElementById('comment-name');
        const starsInput = document.getElementById('comment-stars');
        const textInput = document.getElementById('comment-text');

        const name = nameInput.value.trim();
        const stars = starsInput.value;
        const text = textInput.value.trim();

        if (!name || !text) return;

        // Crear una nueva tarjeta de comentario
        const card = document.createElement('article');
        card.className = 'testimonial-card';
        card.style.animation = 'fadeInUp 0.6s ease forwards';
        
        card.innerHTML = `
          <div class="stars">${stars}</div>
          <p>“${text}”</p>
          <span class="comment-author">— ${name}</span>
        `;

        // Agregar la tarjeta al inicio de la lista
        commentsList.insertBefore(card, commentsList.firstChild);

        // Limpiar el formulario
        form.reset();

        // Feedback visual suave
        const submitBtn = form.querySelector('.submit-comment-btn');
        const originalText = submitBtn.innerText;
        submitBtn.innerText = "¡COMENTARIO PUBLICADO!";
        submitBtn.style.background = "#8f6c49";
        
        setTimeout(() => {
          submitBtn.innerText = originalText;
          submitBtn.style.background = "";
        }, 2000);
      });
    }
  });
</script>
