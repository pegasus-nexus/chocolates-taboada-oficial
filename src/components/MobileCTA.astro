<div class="sticky-mobile-cta">
  <a class="btn btn-gold" href="https://wa.me/59179786916?text=Hola%2C%20quiero%20comprar%20Chocolates%20Taboada" target="_blank" rel="noopener">Comprar por WhatsApp →</a>
</div>

<style>
  .sticky-mobile-cta {
    display: none;
    position: fixed;
    left: 14px;
    right: 14px;
    bottom: 14px;
    z-index: 10;
  }

  .sticky-mobile-cta .btn {
    width: 100%;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 54px;
    padding: 16px 26px;
    border-radius: 999px;
    border: 0;
    cursor: pointer;
    font-weight: 800;
    transition: transform 0.3s ease, box-shadow 0.3s ease, filter 0.3s ease;
    text-decoration: none;
  }

  .btn-gold {
    background: linear-gradient(135deg, var(--gold), #F6D983 48%, var(--champagne));
    color: #3A1A08;
    box-shadow: 0 18px 42px rgba(212, 175, 55, 0.34), inset 0 1px 0 rgba(255,255,255,0.55);
    position: relative;
    overflow: hidden;
  }

  .btn-gold::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(100deg, transparent 0%, rgba(255,255,255,0.55) 45%, transparent 70%);
    transform: translateX(-130%);
    animation: shimmer 4.6s ease-in-out infinite;
  }

  .btn:hover { transform: translateY(-3px); filter: brightness(1.04); }
  .btn-gold:hover { box-shadow: 0 24px 58px rgba(212, 175, 55, 0.44); }

  @media (max-width: 640px) {
    .sticky-mobile-cta {
      display: block;
    }
  }
</style>
