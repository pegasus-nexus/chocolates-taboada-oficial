---
---
<section
  id="cajas-especiales"
  class="relative bg-gradient-to-br from-[#FAF5F0] via-[#F3ECE3] to-[#FAF5F0] py-16 md:py-24 border-t border-[#e8dccb]/50 overflow-hidden"
>
  <div
    id="cajas-especiales-bg"
    class="absolute inset-0 bg-gradient-to-br from-[#FAF5F0] via-[#F3ECE3] to-[#FAF5F0] transition-all duration-500"
  >
  </div>

  <div
    class="absolute top-0 right-0 w-96 h-96 bg-gradient-radial from-amber-100/20 to-transparent blur-[100px] opacity-60"
  >
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    
    <!-- ENCABEZADO DE SECCIÓN -->
    <div class="mb-10 md:mb-12 flex justify-start">
      <h2
        class="text-3xl md:text-5xl font-elegante font-bold text-[#2A1612] relative inline-block tracking-tight"
      >
        Colecciones

        <!-- línea elegante -->
        <span
          class="absolute left-0 -bottom-3 w-28 h-[4px] bg-[#dcb041] rounded-full shadow-[0_0_10px_rgba(220,176,65,0.35)]"
        ></span>
      </h2>
    </div>

    <!-- DISPOSICIÓN PRINCIPAL DE 2 COLUMNAS -->
    <div id="cat-main-container" class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 items-start transition-all duration-300">
      
      <!-- BARRA LATERAL ULTRA COMPACTA DE CATEGORÍAS -->
      <aside
        id="cat-sidebar"
        class="lg:col-span-2 bg-white/80 border border-[#e8dccb] backdrop-blur-md rounded-3xl p-3 md:p-3.5 shadow-sm sticky top-28 z-20 transition-all duration-300 w-full"
      >
        <!-- CABECERA -->
        <div class="flex items-center justify-between px-1 py-1 mb-2.5 border-b border-[#e8dccb]/70 pb-2">
          <div id="cat-sidebar-header-title" class="flex items-center gap-1.5 overflow-hidden transition-all duration-300">
            <svg class="w-4 h-4 text-[#8f6c49] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
            </svg>
            <span class="text-[11px] font-extrabold text-[#2A1612] uppercase tracking-wider font-sans truncate">Categorías</span>
          </div>

          <!-- BOTÓN COLAPSAR -->
          <button
            id="toggle-cat-sidebar-btn"
            type="button"
            class="w-7 h-7 rounded-full bg-[#2A1612]/5 hover:bg-[#2A1612] hover:text-[#dcb041] text-[#2A1612] flex items-center justify-center transition-all duration-300 cursor-pointer flex-shrink-0"
            title="Guardar / Expandir categorías"
          >
            <svg id="cat-sidebar-arrow-icon" class="w-3.5 h-3.5 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
            </svg>
          </button>
        </div>

        <!-- LISTA DE CATEGORÍAS -->
        <div id="dynamic-categories-list" class="flex lg:flex-col gap-1 overflow-x-auto lg:overflow-x-visible pb-1 lg:pb-0 scrollbar-none">
          <div class="p-2 text-xs italic text-gray-500">Cargando...</div>
        </div>
      </aside>

      <!-- COLUMNA DERECHA: GRID DE PRODUCTOS -->
      <div id="product-grid-column" class="lg:col-span-10 transition-all duration-300">
        <div id="dynamic-products-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-7 min-h-[450px]">
          <div class="p-2 text-xs italic text-gray-500">Cargando productos exquisitos...</div>
        </div>
        
        <div id="no-products-msg" class="hidden col-span-full py-20 text-center">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-white/50 mb-6 shadow-inner">
                <svg class="w-10 h-10 text-[#dcb041]/50" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
                </svg>
            </div>
            <h3 class="text-2xl font-bold text-[#2A1612] font-serif mb-2">No se encontraron productos</h3>
            <p class="text-[#5D4037]/70 font-sans">Ajusta los filtros o intenta otra búsqueda.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const categoriesList = document.getElementById('dynamic-categories-list');
    const productsGrid = document.getElementById('dynamic-products-grid');
    const noProductsMsg = document.getElementById('no-products-msg');
    
    let allProducts = [];
    let currentCategory = 'ALL';
    let currentCity = localStorage.getItem('taboada_selected_city') || 'cochabamba';
    
    // Obtenemos la URL de la API
    const apiUrl = import.meta.env.PUBLIC_API_URL || "http://localhost:10000/api/v1";

    // Detectar cambios de ciudad
    window.addEventListener('cityChanged', (e) => {
      const detail = (e as CustomEvent).detail;
      if (detail && detail.city) {
        currentCity = detail.city;
        renderProducts();
      }
    });

    async function loadCatalog() {
      try {
        const response = await fetch(`${apiUrl}/fidelizacion/catalog`);
        if (!response.ok) throw new Error('Error fetching catalog');
        
        const data = await response.json();
        
        if (data.status === 'success') {
          // Filtrar categorías que no tienen productos si es necesario (opcional)
          renderCategories(data.categorias);
          allProducts = data.productos;
          renderProducts();
          setupSidebarToggle();
        }
      } catch (error) {
        console.error('Error cargando catálogo:', error);
        if (productsGrid) {
          productsGrid.innerHTML = '<div class="col-span-full text-center text-red-500 py-10">Ocurrió un error al cargar el catálogo.</div>';
        }
      }
    }

    function getCategoryIcon(name) {
      // Retorna un SVG string en base al nombre
      return `<svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>`;
    }

    function getCategoryFallbackIcon() {
        return `<svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" /></svg>`;
    }

    function renderCategories(categorias) {
      if (!categoriesList) return;
      
      let html = `
        <div class="relative group/cat-tooltip flex-shrink-0 lg:flex-shrink w-full">
          <button
            type="button"
            class="cat-btn w-full flex items-center gap-2.5 px-3 py-2 rounded-xl text-xs font-bold transition-all duration-300 cursor-pointer text-left group bg-[#2A1612] text-[#dcb041] shadow-sm border border-[#2A1612]"
            data-target="ALL"
          >
            <span class="cat-btn-label flex-1 truncate text-[11px] font-sans tracking-tight">Todas</span>
          </button>
          <span class="cat-floating-tooltip absolute left-full top-1/2 -translate-y-1/2 ml-3 px-2.5 py-1 bg-[#2A1612] text-white text-[11px] font-bold rounded-lg shadow-xl opacity-0 pointer-events-none transition-opacity duration-200 z-50 whitespace-nowrap border border-white/10 hidden group-hover/cat-tooltip:opacity-100">
            Todas
          </span>
        </div>
      `;

      categorias.forEach(cat => {
        html += `
          <div class="relative group/cat-tooltip flex-shrink-0 lg:flex-shrink w-full">
            <button
              type="button"
              class="cat-btn w-full flex items-center gap-2.5 px-3 py-2 rounded-xl text-xs font-bold transition-all duration-300 cursor-pointer text-left group text-[#5D4037] hover:bg-[#FAF0E6] hover:text-[#2A1612]"
              data-target="${cat.id}"
            >
              <span class="cat-btn-label flex-1 truncate text-[11px] font-sans tracking-tight">${cat.name}</span>
            </button>
            <span class="cat-floating-tooltip absolute left-full top-1/2 -translate-y-1/2 ml-3 px-2.5 py-1 bg-[#2A1612] text-white text-[11px] font-bold rounded-lg shadow-xl opacity-0 pointer-events-none transition-opacity duration-200 z-50 whitespace-nowrap border border-white/10 hidden group-hover/cat-tooltip:opacity-100">
              ${cat.name}
            </span>
          </div>
        `;
      });
      categoriesList.innerHTML = html;

      // Eventos de click en categorías
      const catBtns = categoriesList.querySelectorAll('.cat-btn');
      catBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          // Remover activo de todos
          catBtns.forEach(b => {
            b.classList.remove('bg-[#2A1612]', 'text-[#dcb041]', 'shadow-sm', 'border-[#2A1612]', 'border');
            b.classList.add('text-[#5D4037]', 'hover:bg-[#FAF0E6]', 'hover:text-[#2A1612]');
          });
          // Añadir activo al clickeado
          btn.classList.add('bg-[#2A1612]', 'text-[#dcb041]', 'shadow-sm', 'border', 'border-[#2A1612]');
          btn.classList.remove('text-[#5D4037]', 'hover:bg-[#FAF0E6]', 'hover:text-[#2A1612]');
          
          currentCategory = (btn as HTMLElement).dataset.target || 'ALL';
          renderProducts();
        });
      });
    }

    function renderProducts() {
      if (!productsGrid) return;
      
      const filtered = allProducts.filter(p => {
        const matchCategory = currentCategory === 'ALL' || p.categoria_id === currentCategory;
        const hasPriceForCity = p.precios && p.precios[currentCity] !== undefined;
        return matchCategory && hasPriceForCity;
      });

      if (filtered.length === 0) {
        productsGrid.innerHTML = '';
        if(noProductsMsg) noProductsMsg.classList.remove('hidden');
        return;
      }
      
      if(noProductsMsg) noProductsMsg.classList.add('hidden');
      
      let html = '';
      filtered.forEach(p => {
        const price = p.precios[currentCity];
        const wappText = encodeURIComponent(`Hola, quiero comprar el producto: ${p.nombre}`);
        const imgUrl = p.imagen || '/img/produc1.png'; // Fallback
        const weight = p.codigo_corto || '100g';
        const desc = p.descripcion || 'El verdadero sabor del cacao seleccionado.';
        
        html += `
          <div class="product-card group relative bg-[#fbf8f3]/95 rounded-[2rem] p-6 border border-[#e8dccb] flex flex-col overflow-hidden transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_8px_30px_rgb(251,207,232,0.4)]">
            <!-- Botón Añadir -->
            <div class="absolute top-5 right-5 z-20 group/tooltip">
              <button
                type="button"
                class="add-to-cart-btn w-10 h-10 bg-white/90 hover:bg-[#2A1612] hover:text-[#dcb041] border border-[#2A1612]/10 text-[#2A1612] rounded-full flex items-center justify-center transition-all duration-300 shadow-md hover:scale-105 active:scale-95 cursor-pointer"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                </svg>
              </button>
              <span class="absolute right-0 -bottom-9 bg-[#2A1612] text-white text-[10px] font-bold px-2.5 py-1 rounded-md shadow-lg whitespace-nowrap opacity-0 pointer-events-none group-hover/tooltip:opacity-100 transition-opacity duration-300 z-30 border border-white/10">
                Añadir al carrito
              </span>
            </div>

            <!-- IMAGEN -->
            <div class="w-full h-56 mb-6 flex items-center justify-center relative z-10">
              <img src="${imgUrl}" alt="${p.nombre}" class="max-w-full max-h-full object-contain filter drop-shadow-[0_15px_15px_rgba(0,0,0,0.15)] group-hover:scale-110 transition-transform duration-500" />
            </div>

            <!-- INFO -->
            <div class="flex flex-col flex-1 relative z-10">
              <h3 class="text-[22px] font-bold text-[#2A1612] font-serif leading-tight mb-1 group-hover:text-[#8f6c49] transition-colors duration-300">${p.nombre}</h3>
              <p class="text-[13px] font-bold text-[#8f6c49] mb-2 uppercase tracking-wide">${weight}</p>
              
              <p class="text-[13px] text-[#5D4037]/80 line-clamp-2 leading-relaxed mb-6 font-sans">
                ${desc}
              </p>
              
              <hr class="border-[#e8dccb] mb-4" />
              
              <div class="flex items-end justify-between mt-auto">
                <div class="flex flex-col">
                  <span class="text-[10px] font-extrabold text-[#a08b7a] uppercase tracking-wider mb-1">Precio</span>
                  <span class="text-2xl font-black text-[#2A1612] font-serif leading-none tracking-tight">BS. ${price}</span>
                </div>
                <a 
                  href="https://wa.me/59179786916?text=${wappText}" 
                  target="_blank" 
                  rel="noopener"
                  class="buy-btn bg-[#f0dba3] hover:bg-[#dcb041] text-[#2A1612] font-bold text-xs px-5 py-2.5 rounded-full transition-all duration-300 shadow-sm cursor-pointer whitespace-nowrap inline-flex items-center justify-center"
                >
                  Comprar
                </a>
              </div>
            </div>
          </div>
        `;
      });
      productsGrid.innerHTML = html;
    }

    // Toggle de la barra lateral (lógica extraída de index.astro)
    function setupSidebarToggle() {
      const catSidebar = document.getElementById('cat-sidebar');
      const toggleSidebarBtn = document.getElementById('toggle-cat-sidebar-btn');
      const arrowIcon = document.getElementById('cat-sidebar-arrow-icon');
      const headerTitle = document.getElementById('cat-sidebar-header-title');
      const productGridColumn = document.getElementById('product-grid-column');

      toggleSidebarBtn?.addEventListener('click', () => {
        const isCollapsed = catSidebar?.classList.contains('is-collapsed-sidebar');

        if (isCollapsed) {
          // EXPANDIR
          catSidebar?.classList.remove('is-collapsed-sidebar', 'lg:col-span-1', 'lg:w-[70px]');
          catSidebar?.classList.add('lg:col-span-2', 'w-full');
          
          productGridColumn?.classList.remove('lg:col-span-11');
          productGridColumn?.classList.add('lg:col-span-10');

          if (arrowIcon) arrowIcon.style.transform = 'rotate(0deg)';
          if (headerTitle) headerTitle.style.display = '';

          document.querySelectorAll('.cat-btn-label').forEach(el => (el as HTMLElement).style.display = '');
          document.querySelectorAll('.cat-btn').forEach(btn => {
            btn.classList.remove('justify-center');
            btn.classList.add('gap-2.5');
          });
        } else {
          // COLAPSAR
          catSidebar?.classList.add('is-collapsed-sidebar', 'lg:col-span-1', 'lg:w-[70px]');
          catSidebar?.classList.remove('lg:col-span-2', 'w-full');
          
          productGridColumn?.classList.remove('lg:col-span-10');
          productGridColumn?.classList.add('lg:col-span-11');

          if (arrowIcon) arrowIcon.style.transform = 'rotate(180deg)';
          if (headerTitle) headerTitle.style.display = 'none';

          document.querySelectorAll('.cat-btn-label').forEach(el => (el as HTMLElement).style.display = 'none');
          document.querySelectorAll('.cat-btn').forEach(btn => {
            btn.classList.add('justify-center');
            btn.classList.remove('gap-2.5');
          });
        }
      });
    }

    loadCatalog();
  });
</script>
